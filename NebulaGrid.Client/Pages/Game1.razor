@page "/game1"
@using NebulaGrid.Shared.Services
@using NebulaGrid.Shared.Models
@inject PlayerService PlayerService
@inject GameStatus Status
@inject HttpClient HttpClient

<PageTitle>Space Game - HQ</PageTitle>

<style>
    .hq-shell {
        position: relative;
    }

    .resource-display {
        margin: 30px 0;
        font-size: 2.5rem;
        font-weight: bold;
        text-shadow: 0 0 10px #00d4ff;
    }

    .orbit-btn {
        background: linear-gradient(45deg, #004e92, #000428);
        color: white;
        border: 2px solid #00d4ff;
        padding: 15px 30px;
        cursor: pointer;
        font-size: 1.2rem;
        border-radius: 8px;
        transition: all 0.2s ease;
        margin: 10px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .orbit-btn:hover {
        background: linear-gradient(45deg, #00d4ff, #004e92);
        transform: scale(1.05);
        box-shadow: 0 0 15px #00d4ff;
    }

    .orbit-btn:active {
        transform: scale(0.95);
    }

    .btn-reset {
        border-color: #ff4b2b;
        color: #ff4b2b;
        background: transparent;
        font-size: 0.9rem;
    }

    .btn-reset:hover {
        background: #ff4b2b;
        color: white;
        box-shadow: 0 0 15px #ff4b2b;
    }

    .space-bg {
        background-color: #050510;
        color: #00d4ff;
        padding: 50px;
        border-radius: 15px;
        text-align: center;
        border: 2px solid #1b6ec2;
        margin-top: 20px;
    }

    .admin-panel {
        margin-top: 50px;
        padding: 20px;
        border-top: 1px dashed #444;
        background: rgba(255, 0, 0, 0.05);
        border-radius: 0 0 15px 15px;
    }

    .btn-reset {
        border: 1px solid #ff4b2b;
        color: #ff4b2b;
        background: transparent;
        padding: 8px 15px;
        cursor: pointer;
        border-radius: 5px;
        font-size: 0.8rem;
    }

    .btn-reset:hover {
        background: #ff4b2b;
        color: white;
    }

    .floating-text-layer {
        position: absolute;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
    }

    .floating-text {
        position: absolute;
        left: 50%;
        top: 110px;
        transform: translateX(-50%);
        color: #f1c46a;
        font-weight: 800;
        text-shadow: 0 0 12px rgba(241, 196, 106, 0.45);
        animation: floatUp 1s ease-out forwards;
    }

    @@keyframes floatUp {
        0% { opacity: 0; transform: translate(-50%, 12px) scale(0.92); }
        15% { opacity: 1; }
        100% { opacity: 0; transform: translate(-50%, -52px) scale(1.05); }
    }
</style>

<div class="hq-shell">
<div class="space-bg">
    <h1>🚀 Space Idle Terminal</h1>

    <button class="orbit-btn" @onclick="AddMoneyAndSave">Collect (+5000)</button>

    <div class="admin-panel">
        <p style="color: #666; font-size: 0.8rem;">Danger zone / System administration</p>
        <button class="btn-reset" @onclick="FullReset">FULL DATA RESET</button>
    </div>
</div>
<div class="floating-text-layer">
    @foreach (var text in floatingTexts)
    {
        <div class="floating-text" style="margin-left:@text.OffsetPx px; color:@text.Color">@text.Text</div>
    }
</div>
</div>

@code {
    private Game1State game1State = new Game1State();
    private readonly List<FloatingText> floatingTexts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadGame1State();
    }

    private async Task LoadGame1State()
    {
        try
        {
            game1State = await HttpClient.GetFromJsonAsync<Game1State>("api/game/game1state") ?? new Game1State();
        }
        catch
        {
            game1State = new Game1State();
        }
    }

    private async Task SaveGame1State()
    {
        try
        {
            await HttpClient.PostAsJsonAsync("api/game/savegame1state", game1State);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving game1 state: {ex.Message}");
        }
    }

    private async Task SavePlayerAsync()
    {
        if (PlayerService.SelectedPlayerId <= 0)
        {
            return;
        }

        var response = await HttpClient.PostAsJsonAsync("api/game/saveplayer", PlayerService.ToPlayer());
        response.EnsureSuccessStatusCode();
        await RefreshAccountProgressAsync();
    }

    private async Task RefreshAccountProgressAsync()
    {
        if (PlayerService.AccountProfileId <= 0)
        {
            return;
        }

        var account = await HttpClient.GetFromJsonAsync<AccountProfile>($"api/game/account/{PlayerService.AccountProfileId}");
        if (account is not null)
        {
            PlayerService.UpdateAccount(account);
        }
    }

    private async Task AddMoneyAndSave()
    {
        var creditBurst = 5000;
        var fuelBurst = 0;
        var xpBurst = 0;

        switch (PlayerService.ActiveCommanderClass)
        {
            case "Quartermaster":
                fuelBurst = 6 + PlayerService.ActiveCommanderLogisticsSkill + PlayerService.ActiveCommanderLogisticsTreeLevel;
                creditBurst += 400;
                break;
            case "Vanguard":
                xpBurst = 40 + (PlayerService.ActiveCommanderReactorSkill * 10) + (PlayerService.ActiveCommanderReactorTreeLevel * 15);
                break;
            default:
                creditBurst += 1500 + (PlayerService.ActiveCommanderMiningSkill * 250) + (PlayerService.ActiveCommanderMiningTreeLevel * 400);
                break;
        }

        PlayerService.Resource1 += creditBurst;
        PlayerService.Resource2 += fuelBurst;
        PlayerService.AddXP(xpBurst);

        AddFloatingText($"+{creditBurst} Credits", "#f1c46a", -90);
        if (fuelBurst > 0)
        {
            AddFloatingText($"+{fuelBurst} Fuel", "#8fdcff", 0);
        }

        if (xpBurst > 0)
        {
            AddFloatingText($"+{xpBurst} XP", "#92ffc6", 90);
        }

        game1State.LastSaved = DateTime.UtcNow;
        await SaveGame1State();
        await SavePlayerAsync();
        Status.NotifyResourceChanged();
    }

    private void AddFloatingText(string text, string color, int offsetPx)
    {
        var entry = new FloatingText
        {
            Id = Guid.NewGuid(),
            Text = text,
            Color = color,
            OffsetPx = offsetPx
        };

        floatingTexts.Add(entry);
        _ = Task.Run(async () =>
        {
            await Task.Delay(1000);
            await InvokeAsync(() =>
            {
                floatingTexts.RemoveAll(item => item.Id == entry.Id);
                StateHasChanged();
            });
        });
    }

    private sealed class FloatingText
    {
        public Guid Id { get; set; }
        public string Text { get; set; } = string.Empty;
        public string Color { get; set; } = "#f1c46a";
        public int OffsetPx { get; set; }
    }

    private async Task FullReset()
    {
        PlayerService.Resource1 = 0;
        PlayerService.Resource2 = 0;
        PlayerService.Alloy = 0;
        PlayerService.Biomass = 0;
        PlayerService.CurrentXP = 0;
        PlayerService.CurrentLevel = 1;
        game1State = new Game1State();
        await SaveGame1State();
        await SavePlayerAsync();
        Status.NotifyResourceChanged();
    }
}