        margin: 0;
    }

    .unlock-stage-tag,
    .class-card-state {
        display: inline-flex;
        width: fit-content;
        padding: 5px 10px;
        border-radius: 999px;
        background: rgba(7, 16, 24, 0.5);
        color: #f1c46a;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.7rem;
        font-weight: 700;
    }

    .unlock-meter-shell {
        display: grid;
        gap: 10px;
        justify-items: center;
        color: rgba(246, 244, 239, 0.78);
    }

    .unlock-meter-ring {
        width: 110px;
        height: 110px;
        border-radius: 999px;
        display: grid;
        justify-items: center;
        align-content: center;
        gap: 2px;
        background:
            radial-gradient(circle at center, rgba(8, 19, 31, 0.96) 46%, transparent 47%),
