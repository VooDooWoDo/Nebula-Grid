    .unlock-meter-ring strong,
    .unlock-meter-ring span {
        display: block;
        text-align: center;
        line-height: 1.1;
    }

    .unlock-meter-ring strong {
        font-size: 1.15rem;
    }

    .unlock-meter-ring span {
        font-size: 0.82rem;
    }

    .class-pick-panel-live {
        margin-top: 16px;
        border: 1px solid rgba(143, 220, 255, 0.2);
    }

    .class-pick-grid-live {
        margin-top: 12px;
    }

    .class-pick-card.ready {
        box-shadow: 0 10px 24px rgba(143, 220, 255, 0.08);
    }

    .class-pick-card.spent {
        filter: saturate(0.4);
    }

    .class-card-head {
        display: flex;
        justify-content: space-between;
        align-items: start;
        gap: 8px;
    }

    .lock-track {
        height: 10px;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(7, 16, 24, 0.55);
    }

    .lock-track-fill {
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, #8fdcff, #f1c46a);
    }

    .academy-skill,
    .academy-talent {
        display: grid;
        gap: 12px;
        align-items: center;
    }

    .academy-skill {
        grid-template-columns: 1fr auto auto;
    }

    .academy-talent {
        grid-template-columns: 1fr auto;
    }

    .favored {
        border: 1px solid rgba(241, 196, 106, 0.28);
    }

    .skill-upgrade,
    .talent-upgrade,
    .class-pick-card {
        border: none;
        border-radius: 18px;
        font-weight: 700;
    }

    .skill-upgrade {
        padding: 10px 14px;
        background: linear-gradient(90deg, #f1c46a, #f59b52);
        color: #1b1308;
    }

    .talent-upgrade {
        padding: 10px 14px;
        background: linear-gradient(90deg, #8fdcff, #3bc6b3);
        color: #071018;
    }

    .skill-upgrade:disabled,
    .talent-upgrade:disabled,
    .class-pick-card:disabled {
        opacity: 0.45;
        cursor: not-allowed;
    }

    .academy-assignment,
    .class-pick-panel,
    .academy-talent-copy {
        display: grid;
        gap: 6px;
    }

    .class-pick-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
        margin-top: 10px;
    }

