@page "/playerselection"
@page "/hangar"
@using System.Net.Http.Json
@using NebulaGrid.Shared.Models
@using NebulaGrid.Shared.Services
@inject PlayerService PlayerService
@inject NavigationManager NavManager
@inject GameStatus Status
@inject HttpClient HttpClient
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="selection-container">
    <h1>Pilot Hangar</h1>
    <p class="selection-lede">This screen is only for the active account's pilot roster. Switch local profiles on the Accounts screen, then manage pilot slots here.</p>

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <p class="selection-error">@loadError</p>
    }

    @if (account is null)
    {
        <section class="account-create-card no-account-card">
            <div>
                <p class="slot-tag">No Active Account</p>
                <h2>Choose a local profile first</h2>
                <p>The hangar only shows pilots for the currently selected account.</p>
                <button class="create-character-button wide-action" @onclick='() => NavManager.NavigateTo("/accounts")'>Open Accounts</button>
            </div>
        </section>
    }
    else
    {
        <section class="account-summary-card hangar-summary-card">
            <div class="hangar-summary-head">
                <div>
                    <p class="slot-tag">Active Account</p>
                    <h2>@account.AccountName</h2>
                    <p>One account owns multiple pilots. Manage permanent class picks and pilot skills in Pilot Academy.</p>
                </div>
                <div class="hangar-actions">
                    <button class="secondary-action-button" type="button" @onclick='() => NavManager.NavigateTo("/accounts")'>Switch Account</button>
                    <button class="logout-button" @onclick="LogoutAsync">Sign Out</button>
                </div>
            </div>

            <div class="account-meta-grid">
                <div class="account-meta-pill">
                    <strong>Account LVL @account.AccountLevel</strong>
                    <span>@account.AccountXP / @account.AccountXPToNextLevel XP</span>
                </div>
                <div class="account-meta-pill">
                    <strong>Fleet Levels</strong>
                    <span>@account.CombinedPilotLevels pilot levels</span>
                </div>
                <div class="account-meta-pill">
                    <strong>Account Bonus</strong>
                    <span>+@account.CreditBonusPercent% Credits</span>
                </div>
                <div class="account-meta-pill">
                    <strong>Unlocked Slots</strong>
                    <span>@account.UnlockedSlotCount / 3 online</span>
                </div>
            </div>

            <div class="hangar-preview-toolbar">
                <div>
                    <p class="slot-tag">Offline Forecast</p>
                    <strong>@GetPreviewWindowLabel()</strong>
                </div>
                <div class="hangar-preview-switches">
                    <button class="preview-window-button @(previewWindowMinutes == 60 ? "active" : string.Empty)" type="button" @onclick='() => SetPreviewWindow(60)'>1h</button>
                    <button class="preview-window-button @(previewWindowMinutes == 480 ? "active" : string.Empty)" type="button" @onclick='() => SetPreviewWindow(480)'>8h</button>
                    <button class="preview-window-button @(previewWindowMinutes == 1440 ? "active" : string.Empty)" type="button" @onclick='() => SetPreviewWindow(1440)'>24h</button>
                </div>
            </div>

            <div class="hangar-focus-toolbar">
                <div>
                    <p class="slot-tag">Roster Priority</p>
                    <strong>@GetPreviewFocusLabel()</strong>
                </div>
                <div class="hangar-preview-switches">
                    <button class="preview-window-button @(previewFocus == "credits" ? "active" : string.Empty)" type="button" @onclick='() => SetPreviewFocus("credits")'>Credits</button>
                    <button class="preview-window-button @(previewFocus == "fuel" ? "active" : string.Empty)" type="button" @onclick='() => SetPreviewFocus("fuel")'>Fuel</button>
                    <button class="preview-window-button @(previewFocus == "xp" ? "active" : string.Empty)" type="button" @onclick='() => SetPreviewFocus("xp")'>Player XP</button>
                    <button class="preview-window-button @(previewFocus == "reserve-xp" ? "active" : string.Empty)" type="button" @onclick='() => SetPreviewFocus("reserve-xp")'>Reserve Pilot XP</button>
                    <button class="preview-window-button @(previewFocus == "next-level" ? "active" : string.Empty)" type="button" @onclick='() => SetPreviewFocus("next-level")'>Next Level</button>
                </div>
            </div>

            <div class="fleet-forecast-grid">
                <div class="fleet-forecast-pill">
                    <strong>Fleet Credits</strong>
                    <span>+@GetFleetPreviewCredits() in @GetPreviewWindowShortLabel()</span>
                </div>
                <div class="fleet-forecast-pill">
                    <strong>Fleet Fuel</strong>
                    <span>+@GetFleetPreviewFuel() in @GetPreviewWindowShortLabel()</span>
                </div>
                <div class="fleet-forecast-pill">
                    <strong>Fleet Player XP</strong>
                    <span>+@GetFleetPreviewPlayerXp() in @GetPreviewWindowShortLabel()</span>
                </div>
                <div class="fleet-forecast-pill">
                    <strong>Fleet Reserve Pilot XP</strong>
                    <span>+@GetFleetPreviewReserveXp() in @GetPreviewWindowShortLabel()</span>
                </div>
                <div class="fleet-forecast-pill forecast-growth-pill">
                    <strong>Fleet Reserve Growth</strong>
                    <span>About +@GetFleetProjectedReserveLevels() LVL in @GetPreviewWindowShortLabel()</span>
                </div>
                <div class="fleet-forecast-pill forecast-growth-pill">
                    <strong>Reserve Level-Ups</strong>
                    <span>@GetPilotsWithProjectedLevelUps() pilots in @GetPreviewWindowShortLabel()</span>
                </div>
            </div>

            <div class="hangar-recommendation-card">
                <p class="slot-tag">Recommendation</p>
                <strong>@GetReserveRecommendationTitle()</strong>
                <p>@GetReserveRecommendationText()</p>
                <label class="recommendation-toggle">
                    <input type="checkbox" checked="@autoOptimizeHangar" @onchange="ToggleAutoOptimizeHangarAsync" />
                    <span>Auto-optimize on open</span>
                </label>
                <button class="secondary-action-button recommendation-action" type="button" @onclick="OptimizeReserveView">
                    @GetReserveRecommendationActionLabel()
                </button>
            </div>

            @if (ShouldShowSetupCard())
            {
                <div class="hangar-setup-card">
                    <p class="slot-tag">Setup</p>
                    <strong>@GetSetupCardTitle()</strong>
                    <p>@GetSetupCardText()</p>
                    <button class="secondary-action-button recommendation-action" type="button" @onclick="RunSetupActionAsync">
                        @GetSetupCardActionLabel()
                    </button>
                </div>
            }

            <div class="hangar-top-picks-grid">
                <button class="hangar-top-pick-card @(IsTopPickActive("credits") ? "active" : string.Empty)" type="button" @onclick='() => ApplyTopPickMode("credits")'>
                    <p class="slot-tag">Top Credits</p>
                    <strong>@GetTopPickName("credits")</strong>
                    <span>@GetTopPickValueText("credits")</span>
                    <small>@GetTopPickLeadText("credits")</small>
                </button>
                    <button class="hangar-top-pick-card hangar-top-pick-card-featured @(IsAllRoundPickActive() ? "active" : string.Empty)" type="button" @onclick="ApplyAllRoundRecommendation">
                        <p class="slot-tag">Best All-Round</p>
                        <strong>@GetAllRoundPickName()</strong>
                        <span>@GetAllRoundPickHeadline()</span>
                        <em>@GetAllRoundTimeShiftNote()</em>
                        <small>@GetAllRoundPickReason()</small>
                    </button>
                <button class="hangar-top-pick-card hangar-top-pick-card-warning @(IsWeakSpotActive() ? "active" : string.Empty)" type="button" @onclick="ApplyWeakSpotFocus">
                    <p class="slot-tag">Weak Spot</p>
                    <strong>@GetWeakSpotTitle()</strong>
                    <span>@GetWeakSpotHeadline()</span>
                    <em>@GetWeakSpotFixerLabel()</em>
                    <small>@GetWeakSpotReason()</small>
                </button>
                <button class="hangar-top-pick-card @(IsTopPickActive("fuel") ? "active" : string.Empty)" type="button" @onclick='() => ApplyTopPickMode("fuel")'>
                    <p class="slot-tag">Top Fuel</p>
                    <strong>@GetTopPickName("fuel")</strong>
                    <span>@GetTopPickValueText("fuel")</span>
                    <small>@GetTopPickLeadText("fuel")</small>
                </button>
                <button class="hangar-top-pick-card @(IsTopPickActive("xp") ? "active" : string.Empty)" type="button" @onclick='() => ApplyTopPickMode("xp")'>
                    <p class="slot-tag">Top Player XP</p>
                    <strong>@GetTopPickName("xp")</strong>
                    <span>@GetTopPickValueText("xp")</span>
                    <small>@GetTopPickLeadText("xp")</small>
                </button>
                <button class="hangar-top-pick-card @(IsTopPickActive("reserve-growth") ? "active" : string.Empty)" type="button" @onclick='() => ApplyTopPickMode("reserve-growth")'>
                    <p class="slot-tag">Top Reserve Growth</p>
                    <strong>@GetTopPickName("reserve-growth")</strong>
                    <span>@GetTopPickValueText("reserve-growth")</span>
                    <small>@GetTopPickLeadText("reserve-growth")</small>
                </button>
            </div>

            <p class="fleet-forecast-note">Reserve Pilot XP is earned by your inactive pilots and raises their own pilot levels for stronger future offline output.</p>
        </section>

        <div class="pilot-card-grid">
            @foreach (var slot in GetOrderedSlots())
            {
                <article class="pilot-card @(slot.Player is null ? (slot.IsUnlocked ? "open-slot" : "locked-slot") : string.Empty)" @onclick="() => HandleSlotClick(slot)">
                    <div class="pilot-card-crest">@GetSlotVisual(slot)</div>
                    <div class="pilot-card-copy">
                        <p class="slot-tag">Slot @slot.SlotId</p>
                        <h3>@(slot.Player?.PlayerName ?? (slot.IsUnlocked ? "Create New Pilot" : "Locked Slot"))</h3>
                        <span class="card-level">@(slot.Player is null ? (slot.IsUnlocked ? "OPEN" : $"LVL {slot.UnlockLevelRequirement}") : $"LVL {slot.Player.Level}")</span>
                    </div>

                    @if (slot.Player is not null)
                    {
                        <div class="pilot-card-badges">
                            @if (GetPilotFocusRank(slot.Player) is int focusRank)
                            {
                                <span class="pilot-card-badge pilot-card-badge-focus">#@focusRank @GetPreviewFocusBadgeLabel()</span>
                            }
                            @if (IsBestCreditPilot(slot.Player))
                            {
                                <span class="pilot-card-badge">Best Credits</span>
                            }
                            @if (IsBestFuelPilot(slot.Player))
                            {
                                <span class="pilot-card-badge">Best Fuel</span>
                            }
                            @if (IsBestXpPilot(slot.Player))
                            {
                                <span class="pilot-card-badge">Best XP</span>
                            }
                            @if (IsBestReserveXpPilot(slot.Player))
                            {
                                <span class="pilot-card-badge">Best Reserve XP</span>
                            }
                            @if (IsBestReserveGrowthPilot(slot.Player))
                            {
                                <span class="pilot-card-badge pilot-card-badge-growth">Best Growth</span>
                            }
                            @if (IsBestNextReservePilot(slot.Player))
                            {
                                <span class="pilot-card-badge pilot-card-badge-soon">Next Up</span>
                            }
                            @if (HasProjectedReserveLevelUp(slot.Player))
                            {
                                <span class="pilot-card-badge pilot-card-badge-growth">Levels Up</span>
                            }
                            else if (IsProjectedReserveNearLevelUp(slot.Player))
                            {
                                <span class="pilot-card-badge pilot-card-badge-soon">Near Level-Up</span>
                            }
                        </div>
                    }

                    @if (slot.Player is not null)
                    {
                        <div class="pilot-card-stats">
                            <p>@GetPilotClassLabel(slot.Player)</p>
                            <p>@GetReserveJobLabel(slot.Player)</p>
                            <p>@GetReserveJobSummary(slot.Player)</p>
                            <p class="pilot-card-preview">@GetReserveJobPreview(slot.Player)</p>
                            <p class="pilot-card-growth">@GetReserveLevelProjection(slot.Player)</p>
                            <div class="pilot-card-growth-panel @GetReserveGrowthPanelClass(slot.Player)">
                                <div class="pilot-card-growth-row">
                                    <span>Reserve progress after @GetPreviewWindowShortLabel()</span>
                                    <span>@GetProjectedReserveProgressLabel(slot.Player)</span>
                                </div>
                                <div class="pilot-card-growth-track">
                                    <div class="pilot-card-growth-fill @GetReserveGrowthFillClass(slot.Player)" style="width: @GetProjectedReserveProgressPercent(slot.Player).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                </div>
                            </div>
                            <p>Credits: @slot.Player.Resource1</p>
                            <p>XP: @slot.Player.XP</p>
                        </div>

                        <div class="pilot-card-actions" @onclick:stopPropagation="true">
                            <button class="create-character-button primary-action" type="button" @onclick="() => EnterCharacterAsync(slot.Player.PlayerID)">
                                Enter Character
                            </button>
                            <button class="secondary-action-button" type="button" @onclick="() => OpenPilotAcademyAsync(slot.Player.PlayerID)">
                                Pilot Academy
                            </button>
                            <button class="secondary-action-button" type="button" @onclick="() => OpenTownAsync(slot.Player.PlayerID)">
                                Frontier Hub
                            </button>
                        </div>
                    }
                    else if (slot.IsUnlocked)
                    {
                        <div class="pilot-card-stats">
                            <p>@slot.UnlockText</p>
                        </div>
                        <button class="create-character-button primary-action wide-action" type="button" @onclick:stopPropagation="true" @onclick="() => OpenCreateCharacterModal(slot.SlotId)">
                            Create Pilot
                        </button>
                    }
                    else
                    {
                        <div class="pilot-card-stats locked-copy">
                            <p>@slot.UnlockText</p>
                        </div>
                    }
                </article>
            }
        </div>
    }

    @if (isCreateModalOpen && activeCreateSlotId is int modalSlotId)
    {
        <div class="modal-backdrop" @onclick="CloseCreateCharacterModal">
            <div class="create-modal" @onclick:stopPropagation="true">
                <div class="create-modal-head">
                    <div>
                        <p class="slot-tag">Slot @modalSlotId</p>
                        <h2>Create Pilot</h2>
                    </div>
                    <button class="modal-close" type="button" @onclick="CloseCreateCharacterModal">Close</button>
                </div>

                <p class="create-modal-copy">Pick a pilot name. New pilots start classless and unlock one permanent class choice at Level 3.</p>

                <input class="slot-name-input modal-input"
                       placeholder="Pilot name"
                       @bind="drafts[modalSlotId].PlayerName"
                      @onkeydown='args => HandleCreateCharacterKeyDownAsync(args, modalSlotId)'
                       maxlength="24" />

                <button class="create-character-button wide-action" @onclick="() => CreateCharacterAsync(modalSlotId)">Create Character</button>
            </div>
        </div>
    }
</div>

@code {
    private const string SelectedAccountStorageKey = "nebula.selected-account-id";
    private const string SelectedPlayerStorageKey = "nebula.selected-player-id";
    private const string AutoOptimizeHangarKey = "nebula.hangar-auto-optimize";
    private List<AccountProfile> accounts = new();
    private AccountProfile? account;
    private readonly List<CharacterSlotSummary> slots = new();
    private readonly Dictionary<int, CharacterDraft> drafts = new();
    private readonly Dictionary<int, List<PlayerTownBuilding>> pilotTownBuildings = new();
    private string? loadError;
    private bool isCreateModalOpen;
    private int? activeCreateSlotId;
    private int previewWindowMinutes = 60;
    private string previewFocus = "credits";
    private bool autoOptimizeHangar;

    protected override async Task OnInitializedAsync()
    {
        Status.OnResourceChanged += HandleResourceUpdate;
        await RestoreHangarPreferencesAsync();
        await LoadSlotsAsync();
    }

    private async Task RestoreHangarPreferencesAsync()
    {
        try
        {
            var storedAutoOptimize = await JSRuntime.InvokeAsync<string?>("nebulaStorage.get", AutoOptimizeHangarKey);
            if (bool.TryParse(storedAutoOptimize, out var autoOptimize))
            {
                autoOptimizeHangar = autoOptimize;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Hangar preferences could not be restored: {ex.Message}");
        }
    }

    private async Task LoadSlotsAsync()
    {
        try
        {
            loadError = null;
            if (PlayerService.AccountProfileId > 0)
            {
                account = await HttpClient.GetFromJsonAsync<AccountProfile>($"api/game/account/{PlayerService.AccountProfileId}");
            }

            if (account is null)
            {
                var storedAccountId = await JSRuntime.InvokeAsync<string?>("nebulaStorage.get", SelectedAccountStorageKey);
                if (int.TryParse(storedAccountId, out var accountId) && accountId > 0)
                {
                    account = await HttpClient.GetFromJsonAsync<AccountProfile>($"api/game/account/{accountId}");
                }
            }

            PlayerService.UpdateAccount(account);
            if (account is null)
            {
                slots.Clear();
                PlayerService.ClearAccountContext();
                return;
            }

            var loadedSlots = await HttpClient.GetFromJsonAsync<List<CharacterSlotSummary>>($"api/game/account/{account.AccountProfileID}/slots") ?? new List<CharacterSlotSummary>();
            slots.Clear();
            slots.AddRange(loadedSlots.OrderBy(slot => slot.SlotId));
            await LoadTownBuildingsAsync();

            foreach (var slot in slots)
            {
                if (!drafts.ContainsKey(slot.SlotId))
                {
                    drafts[slot.SlotId] = new CharacterDraft();
                }
            }

            if (autoOptimizeHangar)
            {
                OptimizeReserveView();
            }
        }
        catch (Exception ex)
        {
            slots.Clear();
            pilotTownBuildings.Clear();
            loadError = $"Pilot data could not be loaded: {ex.Message}";
        }
    }

    private async Task LoadTownBuildingsAsync()
    {
        pilotTownBuildings.Clear();

        var pilots = slots.Where(slot => slot.Player is not null)
            .Select(slot => slot.Player!)
            .ToList();

        if (pilots.Count == 0)
        {
            return;
        }

        var townTasks = pilots.Select(async pilot => new
        {
            pilot.PlayerID,
            Buildings = await HttpClient.GetFromJsonAsync<List<PlayerTownBuilding>>($"api/game/player/{pilot.PlayerID}/town") ?? new List<PlayerTownBuilding>()
        });

        foreach (var result in await Task.WhenAll(townTasks))
        {
            pilotTownBuildings[result.PlayerID] = result.Buildings;
        }
    }

    private async void HandleResourceUpdate()
    {
        await LoadSlotsAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Status.OnResourceChanged -= HandleResourceUpdate;
    }

    private async Task EnterCharacterAsync(int id)
    {
        if (await ActivateCharacterAsync(id))
        {
            NavManager.NavigateTo("/galaxy");
        }
    }

    private async Task OpenPilotAcademyAsync(int playerId)
    {
        if (await ActivateCharacterAsync(playerId))
        {
            NavManager.NavigateTo("/academy");
        }
    }

    private async Task OpenTownAsync(int playerId)
    {
        if (await ActivateCharacterAsync(playerId))
        {
            NavManager.NavigateTo("/town");
        }
    }

    private async Task<bool> ActivateCharacterAsync(int id)
    {
        var activeAccount = account;
        if (activeAccount is null)
        {
            loadError = "Select an account first.";
            return false;
        }

        var selected = slots.FirstOrDefault(slot => slot.Player?.PlayerID == id)?.Player;
        if (selected is null)
        {
            return false;
        }

        loadError = null;

        var refreshedPlayer = await HttpClient.GetFromJsonAsync<Player>($"api/game/player/{id}");
        if (refreshedPlayer is null)
        {
            loadError = "Pilot could not be loaded.";
            return false;
        }

        PlayerService.UpdateAccount(activeAccount);
        PlayerService.UpdateFromPlayer(refreshedPlayer);
        PlayerService.SyncActivePilotPresentation();
        await JSRuntime.InvokeVoidAsync("nebulaStorage.set", SelectedAccountStorageKey, activeAccount.AccountProfileID.ToString());
        await JSRuntime.InvokeVoidAsync("nebulaStorage.set", SelectedPlayerStorageKey, refreshedPlayer.PlayerID.ToString());

        var upgrades = await HttpClient.GetFromJsonAsync<List<PlayerUpgrade>>($"api/game/player/{selected.PlayerID}/upgrades") ?? new List<PlayerUpgrade>();
        var research = await HttpClient.GetFromJsonAsync<List<PlayerResearch>>($"api/game/player/{selected.PlayerID}/research") ?? new List<PlayerResearch>();
        var townBuildings = await HttpClient.GetFromJsonAsync<List<PlayerTownBuilding>>($"api/game/player/{selected.PlayerID}/town") ?? new List<PlayerTownBuilding>();
        PlayerService.UpdateUpgrades(upgrades);
        PlayerService.UpdateResearch(research);
        PlayerService.UpdateTownBuildings(townBuildings);

        Status.NotifyResourceChanged();
        return true;
    }

    private async Task CreateCharacterAsync(int slotId)
    {
        if (!drafts.TryGetValue(slotId, out var draft))
        {
            return;
        }

        if (account is null)
        {
            loadError = "Select an account first.";
            return;
        }

        if (string.IsNullOrWhiteSpace(draft.PlayerName))
        {
            loadError = "Pilot name is required.";
            return;
        }

        var response = await HttpClient.PostAsJsonAsync($"api/game/account/{account.AccountProfileID}/slots/{slotId}", new CreateCharacterRequest
        {
            PlayerName = draft.PlayerName
        });

        if (!response.IsSuccessStatusCode)
        {
            loadError = await response.Content.ReadAsStringAsync();
            return;
        }

        var createdPlayer = await response.Content.ReadFromJsonAsync<Player>();
        await LoadSlotsAsync();

        if (createdPlayer is not null)
        {
            isCreateModalOpen = false;
            activeCreateSlotId = null;
            await EnterCharacterAsync(createdPlayer.PlayerID);
        }
    }

    private Task HandleCreateCharacterKeyDownAsync(KeyboardEventArgs args, int slotId)
    {
        if (args.Key == "Enter")
        {
            return CreateCharacterAsync(slotId);
        }

        return Task.CompletedTask;
    }

    private async Task LogoutAsync()
    {
        account = null;
        slots.Clear();
        PlayerService.ClearAccountContext();
        await JSRuntime.InvokeVoidAsync("nebulaStorage.remove", SelectedAccountStorageKey);
        await JSRuntime.InvokeVoidAsync("nebulaStorage.remove", SelectedPlayerStorageKey);
        Status.NotifyResourceChanged();
        NavManager.NavigateTo("/accounts");
    }

    private sealed class CharacterDraft
    {
        public string PlayerName { get; set; } = string.Empty;
    }

    private sealed class OfflinePreviewSummary
    {
        public int Credits { get; init; }
        public int Fuel { get; init; }
        public int PlayerXp { get; init; }
        public int ReserveXp { get; init; }
    }

    private static string GetPilotClassLabel(Player player)
    {
        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return player.Level >= 3 ? "Class ready to choose in Pilot Academy" : "Class unlocks at Level 3";
        }

        return $"Class: {player.PilotClass}";
    }

    private static string GetReserveJobLabel(Player player)
    {
        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return "Idle Duty: unavailable until class is locked";
        }

        return $"Idle Duty: {GetPassiveJobTitle(player.PassiveJobKey, player.PilotClass)}";
    }

    private static string GetReserveJobSummary(Player player)
    {
        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return "Choose a permanent class at Level 3 to unlock reserve jobs.";
        }

        return GetPassiveJobDescription(player.PassiveJobKey, player.PilotClass);
    }

    private string GetReserveJobPreview(Player player)
    {
        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return $"{GetPreviewWindowShortLabel()} preview unlocks after choosing a permanent class.";
        }

        var jobKey = GetNormalizedPassiveJobKey(player.PassiveJobKey, player.PilotClass);
        var preview = GetPreviewSummary(player, previewWindowMinutes);

        return jobKey switch
        {
            "hauling" => $"{GetPreviewWindowShortLabel()} preview: +{preview.Fuel} Fuel, +{preview.ReserveXp} reserve pilot XP.",
            "reactor" => $"{GetPreviewWindowShortLabel()} preview: +{preview.PlayerXp} player XP, +{preview.ReserveXp} reserve pilot XP.",
            _ => $"{GetPreviewWindowShortLabel()} preview: +{preview.Credits} Credits, +{preview.ReserveXp} reserve pilot XP."
        };
    }

    private string GetReserveLevelProjection(Player player)
    {
        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return "Reserve growth starts after the pilot locks a permanent class.";
        }

        var preview = GetPreviewSummary(player, previewWindowMinutes);
        if (preview.ReserveXp <= 0)
        {
            return "No reserve pilot XP forecast for this pilot yet.";
        }

        var projectedLevel = Math.Max(1, player.Level);
        var projectedXp = Math.Max(0, player.XP) + preview.ReserveXp;
        var levelsGained = 0;

        while (projectedXp >= projectedLevel * 100)
        {
            projectedXp -= projectedLevel * 100;
            projectedLevel++;
            levelsGained++;
        }

        return levelsGained > 0
            ? $"Reserve growth: about +{levelsGained} LVL to {projectedLevel}, then {projectedXp}/{projectedLevel * 100} XP."
            : $"Reserve growth: stays LVL {projectedLevel}, then {projectedXp}/{projectedLevel * 100} XP.";
    }

    private string GetProjectedReserveProgressLabel(Player player)
