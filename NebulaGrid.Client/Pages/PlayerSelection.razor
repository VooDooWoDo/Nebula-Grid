    private double GetAllRoundPilotScore(Player player)
    {
        return GetAllRoundPilotScore(player, previewWindowMinutes);
    }

    private double GetAllRoundPilotScore(Player player, int previewMinutes)
    {
        var preview = GetPreviewSummary(player, previewMinutes);
        var maxCredits = Math.Max(1, slots.Where(slot => slot.Player is not null).Select(slot => GetPreviewSummary(slot.Player!, previewMinutes).Credits).DefaultIfEmpty().Max());
        var maxFuel = Math.Max(1, slots.Where(slot => slot.Player is not null).Select(slot => GetPreviewSummary(slot.Player!, previewMinutes).Fuel).DefaultIfEmpty().Max());
        var maxPlayerXp = Math.Max(1, slots.Where(slot => slot.Player is not null).Select(slot => GetPreviewSummary(slot.Player!, previewMinutes).PlayerXp).DefaultIfEmpty().Max());
        var maxReserveXp = Math.Max(1, slots.Where(slot => slot.Player is not null).Select(slot => GetPreviewSummary(slot.Player!, previewMinutes).ReserveXp).DefaultIfEmpty().Max());
        var maxReserveGrowth = Math.Max(1, slots.Where(slot => slot.Player is not null).Select(slot => GetProjectedReserveLevelsGained(slot.Player!, previewMinutes)).DefaultIfEmpty().Max());
        var reservePriorityMax = Math.Max(1, slots.Where(slot => slot.Player is not null).Select(slot => GetProjectedReservePriorityScore(slot.Player!, previewMinutes)).DefaultIfEmpty().Max());

        var reserveGrowthScore = GetProjectedReserveLevelsGained(player, previewMinutes) > 0
            ? (double)GetProjectedReserveLevelsGained(player, previewMinutes) / maxReserveGrowth
            : 0.45d * GetProjectedReservePriorityScore(player, previewMinutes) / reservePriorityMax;

        return (double)preview.Credits / maxCredits
            + (double)preview.Fuel / maxFuel
            + (double)preview.PlayerXp / maxPlayerXp
            + 0.65d * preview.ReserveXp / maxReserveXp
            + 1.35d * reserveGrowthScore;
    }

    private string GetDominantPilotMode(Player player)
    {
        var preview = GetPreviewSummary(player, previewWindowMinutes);
        var creditLead = preview.Credits;
        var fuelLead = preview.Fuel;
        var xpLead = preview.PlayerXp;
        var reserveGrowthLead = GetProjectedReserveLevelsGained(player) > 0
            ? GetProjectedReserveLevelsGained(player) * 1000
            : GetProjectedReservePriorityScore(player);

        if (reserveGrowthLead >= creditLead && reserveGrowthLead >= fuelLead && reserveGrowthLead >= xpLead)
        {
            return "reserve-growth";
        }

        if (fuelLead >= creditLead && fuelLead >= xpLead)
        {
            return "fuel";
        }

        return xpLead > creditLead ? "xp" : "credits";
    }

