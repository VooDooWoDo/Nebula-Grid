@page "/playerselection"
@page "/hangar"
@using System.Net.Http.Json
@using NebulaGrid.Shared.Models
@using NebulaGrid.Shared.Services
@inject PlayerService PlayerService
@inject NavigationManager NavManager
@inject GameStatus Status
@inject HttpClient HttpClient
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="selection-container">
    <h1>Pilot Hangar</h1>
    <p class="selection-lede">This screen is only for the active account's pilot roster. Switch local profiles on the Accounts screen, then manage pilot slots here.</p>

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <p class="selection-error">@loadError</p>
    }

    @if (account is null)
    {
        <section class="account-create-card no-account-card">
            <div>
                <p class="slot-tag">No Active Account</p>
                <h2>Choose a local profile first</h2>
                <p>The hangar only shows pilots for the currently selected account.</p>
                <button class="create-character-button wide-action" @onclick='() => NavManager.NavigateTo("/accounts")'>Open Accounts</button>
            </div>
        </section>
    }
    else
    {
        <section class="account-summary-card hangar-summary-card">
            <div class="hangar-summary-head">
                <div>
                    <p class="slot-tag">Active Account</p>
                    <h2>@account.AccountName</h2>
                    <p>One account owns multiple pilots. Manage permanent class picks and pilot skills in Pilot Academy.</p>
                </div>
                <div class="hangar-actions">
                    <button class="secondary-action-button" type="button" @onclick='() => NavManager.NavigateTo("/accounts")'>Switch Account</button>
                    <button class="logout-button" @onclick="LogoutAsync">Sign Out</button>
                </div>
            </div>

            <div class="account-meta-grid">
                <div class="account-meta-pill">
                    <strong>Account LVL @account.AccountLevel</strong>
                    <span>@account.AccountXP / @account.AccountXPToNextLevel XP</span>
                </div>
                <div class="account-meta-pill">
                    <strong>Fleet Levels</strong>
                    <span>@account.CombinedPilotLevels pilot levels • @account.CombinedCommanderLevels / 3 classes locked</span>
                </div>
                <div class="account-meta-pill">
                    <strong>Account Bonus</strong>
                    <span>+@account.CreditBonusPercent% Credits • +@account.FuelBonusFlat Fuel/s</span>
                </div>
                <div class="account-meta-pill">
                    <strong>Unlocked Slots</strong>
                    <span>@account.UnlockedSlotCount / 3 online</span>
                </div>
            </div>
        </section>

        <div class="pilot-card-grid">
            @foreach (var slot in slots)
            {
                <article class="pilot-card @(slot.Player is null ? (slot.IsUnlocked ? "open-slot" : "locked-slot") : string.Empty)" @onclick="() => HandleSlotClick(slot)">
                    <div class="pilot-card-crest">@GetSlotVisual(slot)</div>
                    <div class="pilot-card-copy">
                        <p class="slot-tag">Slot @slot.SlotId</p>
                        <h3>@(slot.Player?.PlayerName ?? (slot.IsUnlocked ? "Create New Pilot" : "Locked Slot"))</h3>
                        <span class="card-level">@(slot.Player is null ? (slot.IsUnlocked ? "OPEN" : $"LVL {slot.UnlockLevelRequirement}") : $"LVL {slot.Player.Level}")</span>
                    </div>

                    @if (slot.Player is not null)
                    {
                        <div class="pilot-card-stats">
                            <p>@GetPilotClassLabel(slot.Player)</p>
                            <p>Credits: @slot.Player.Resource1</p>
                            <p>XP: @slot.Player.XP</p>
                        </div>

                        <div class="pilot-card-actions" @onclick:stopPropagation="true">
                            <button class="create-character-button primary-action" type="button" @onclick="() => EnterCharacterAsync(slot.Player.PlayerID)">
                                Enter Character
                            </button>
                            <button class="secondary-action-button" type="button" @onclick="() => OpenPilotAcademyAsync(slot.Player.PlayerID)">
                                Pilot Academy
                            </button>
                        </div>
                    }
                    else if (slot.IsUnlocked)
                    {
                        <div class="pilot-card-stats">
                            <p>@slot.UnlockText</p>
                        </div>
                        <button class="create-character-button primary-action wide-action" type="button" @onclick:stopPropagation="true" @onclick="() => OpenCreateCharacterModal(slot.SlotId)">
                            Create Pilot
                        </button>
                    }
                    else
                    {
                        <div class="pilot-card-stats locked-copy">
                            <p>@slot.UnlockText</p>
                        </div>
                    }
                </article>
            }
        </div>
    }

    @if (isCreateModalOpen && activeCreateSlotId is int modalSlotId)
    {
        <div class="modal-backdrop" @onclick="CloseCreateCharacterModal">
            <div class="create-modal" @onclick:stopPropagation="true">
                <div class="create-modal-head">
                    <div>
                        <p class="slot-tag">Slot @modalSlotId</p>
                        <h2>Create Pilot</h2>
                    </div>
                    <button class="modal-close" type="button" @onclick="CloseCreateCharacterModal">Close</button>
                </div>

                <p class="create-modal-copy">Pick a pilot name. New pilots start classless and unlock one permanent class choice at Level 3.</p>

                <input class="slot-name-input modal-input"
                       placeholder="Pilot name"
                       @bind="drafts[modalSlotId].PlayerName"
                       maxlength="24" />

                <button class="create-character-button wide-action" @onclick="() => CreateCharacterAsync(modalSlotId)">Create Character</button>
            </div>
        </div>
    }
</div>

@code {
    private const string SelectedAccountStorageKey = "nebula.selected-account-id";
    private const string SelectedPlayerStorageKey = "nebula.selected-player-id";
    private List<AccountProfile> accounts = new();
    private AccountProfile? account;
    private readonly List<CharacterSlotSummary> slots = new();
    private readonly Dictionary<int, CharacterDraft> drafts = new();
    private string? loadError;
    private bool isCreateModalOpen;
    private int? activeCreateSlotId;

    protected override async Task OnInitializedAsync()
    {
        Status.OnResourceChanged += HandleResourceUpdate;
        await LoadSlotsAsync();
    }

    private async Task LoadSlotsAsync()
    {
        try
        {
            loadError = null;
            if (PlayerService.AccountProfileId > 0)
            {
                account = await HttpClient.GetFromJsonAsync<AccountProfile>($"api/game/account/{PlayerService.AccountProfileId}");
            }

            if (account is null)
            {
                var storedAccountId = await JSRuntime.InvokeAsync<string?>("nebulaStorage.get", SelectedAccountStorageKey);
                if (int.TryParse(storedAccountId, out var accountId) && accountId > 0)
                {
                    account = await HttpClient.GetFromJsonAsync<AccountProfile>($"api/game/account/{accountId}");
                }
            }

            PlayerService.UpdateAccount(account);
            if (account is null)
            {
                slots.Clear();
                PlayerService.ClearAccountContext();
                return;
            }

            var loadedSlots = await HttpClient.GetFromJsonAsync<List<CharacterSlotSummary>>($"api/game/account/{account.AccountProfileID}/slots") ?? new List<CharacterSlotSummary>();
            slots.Clear();
            slots.AddRange(loadedSlots.OrderBy(slot => slot.SlotId));

            foreach (var slot in slots)
            {
                if (!drafts.ContainsKey(slot.SlotId))
                {
                    drafts[slot.SlotId] = new CharacterDraft();
                }
            }
        }
        catch (Exception ex)
        {
            slots.Clear();
            loadError = $"Pilot data could not be loaded: {ex.Message}";
        }
    }

    private async void HandleResourceUpdate()
    {
        await LoadSlotsAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Status.OnResourceChanged -= HandleResourceUpdate;
    }

    private async Task EnterCharacterAsync(int id)
    {
        if (await ActivateCharacterAsync(id))
        {
            NavManager.NavigateTo("/galaxy");
        }
    }

    private async Task OpenPilotAcademyAsync(int playerId)
    {
        if (await ActivateCharacterAsync(playerId))
        {
            NavManager.NavigateTo("/academy");
        }
    }

    private async Task<bool> ActivateCharacterAsync(int id)
    {
        var selected = slots.FirstOrDefault(slot => slot.Player?.PlayerID == id)?.Player;
        if (selected is null)
        {
            return false;
        }

        loadError = null;

        var refreshedPlayer = await HttpClient.GetFromJsonAsync<Player>($"api/game/player/{id}");
        if (refreshedPlayer is null)
        {
            loadError = "Pilot could not be loaded.";
            return false;
        }

        PlayerService.UpdateAccount(account);
        PlayerService.UpdateFromPlayer(refreshedPlayer);
        PlayerService.SyncActivePilotPresentation();

        var upgrades = await HttpClient.GetFromJsonAsync<List<PlayerUpgrade>>($"api/game/player/{selected.PlayerID}/upgrades") ?? new List<PlayerUpgrade>();
        var research = await HttpClient.GetFromJsonAsync<List<PlayerResearch>>($"api/game/player/{selected.PlayerID}/research") ?? new List<PlayerResearch>();
        var townBuildings = await HttpClient.GetFromJsonAsync<List<PlayerTownBuilding>>($"api/game/player/{selected.PlayerID}/town") ?? new List<PlayerTownBuilding>();
        PlayerService.UpdateUpgrades(upgrades);
        PlayerService.UpdateResearch(research);
        PlayerService.UpdateTownBuildings(townBuildings);

        Status.NotifyResourceChanged();
        return true;
    }

    private async Task CreateCharacterAsync(int slotId)
    {
        if (!drafts.TryGetValue(slotId, out var draft))
        {
            return;
        }

        if (account is null)
        {
            loadError = "Select an account first.";
            return;
        }

        if (string.IsNullOrWhiteSpace(draft.PlayerName))
        {
            loadError = "Pilot name is required.";
            return;
        }

        var response = await HttpClient.PostAsJsonAsync($"api/game/account/{account.AccountProfileID}/slots/{slotId}", new CreateCharacterRequest
        {
            PlayerName = draft.PlayerName
        });

        if (!response.IsSuccessStatusCode)
        {
            loadError = await response.Content.ReadAsStringAsync();
            return;
        }

        var createdPlayer = await response.Content.ReadFromJsonAsync<Player>();
        await LoadSlotsAsync();

        if (createdPlayer is not null)
        {
            isCreateModalOpen = false;
            activeCreateSlotId = null;
            await EnterCharacterAsync(createdPlayer.PlayerID);
        }
    }

    private async Task LogoutAsync()
    {
        account = null;
        slots.Clear();
        PlayerService.ClearAccountContext();
        await JSRuntime.InvokeVoidAsync("nebulaStorage.remove", SelectedAccountStorageKey);
        await JSRuntime.InvokeVoidAsync("nebulaStorage.remove", SelectedPlayerStorageKey);
        Status.NotifyResourceChanged();
        NavManager.NavigateTo("/accounts");
    }

    private sealed class CharacterDraft
    {
        public string PlayerName { get; set; } = string.Empty;
    }

    private static string GetPilotClassLabel(Player player)
    {
        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return player.Level >= 3 ? "Class ready to choose in Pilot Academy" : "Class unlocks at Level 3";
        }

        return $"Class: {player.PilotClass}";
    }

    private void HandleSlotClick(CharacterSlotSummary slot)
    {
        if (slot.Player is null && slot.IsUnlocked)
        {
            OpenCreateCharacterModal(slot.SlotId);
        }
    }

    private void OpenCreateCharacterModal(int slotId)
    {
        if (!drafts.ContainsKey(slotId))
        {
            drafts[slotId] = new CharacterDraft();
        }

        activeCreateSlotId = slotId;
        isCreateModalOpen = true;
        loadError = null;
    }

    private void CloseCreateCharacterModal()
    {
        isCreateModalOpen = false;
        activeCreateSlotId = null;
    }

    private static string GetSlotVisual(CharacterSlotSummary slot)
    {
        if (slot.Player is null)
        {
            return slot.IsUnlocked ? "+" : "LOCK";
        }

        return slot.Player.PilotClass switch
        {
            "Prospector" => "⛏",
            "Quartermaster" => "⛴",
            "Vanguard" => "⚡",
            _ => "CORE"
        };
    }
}

<style>
    .selection-container { text-align: center; margin-top: 40px; color: white; padding: 0 20px 30px; }
    .selection-lede { max-width: 760px; margin: 12px auto 0; color: rgba(255, 255, 255, 0.72); }
    .selection-error { color: #ff8080; margin-top: 20px; }
    .hangar-summary-card { max-width: 1200px; margin: 28px auto 0; }
    .hangar-summary-head { display: flex; justify-content: space-between; align-items: start; gap: 18px; }
    .hangar-actions { display: flex; gap: 12px; align-items: center; }
    .logout-button { border: 1px solid rgba(255, 128, 128, 0.35); background: rgba(255, 128, 128, 0.1); color: #ffd0d0; border-radius: 999px; padding: 10px 16px; font-weight: 700; }
    .account-create-card, .account-summary-card { padding: 24px; border-radius: 20px; border: 1px solid rgba(143, 220, 255, 0.28); background: linear-gradient(180deg, rgba(15, 15, 35, 0.96), rgba(8, 15, 29, 0.98)); text-align: left; }
    .no-account-card { max-width: 560px; margin: 36px auto 0; }
    .account-meta-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 12px; margin-top: 18px; }
    .account-meta-pill { padding: 12px 14px; border-radius: 14px; border: 1px solid rgba(143, 220, 255, 0.2); background: rgba(255,255,255,0.04); display: grid; gap: 5px; }
    .account-meta-pill span { color: rgba(255,255,255,0.74); font-size: 0.82rem; }
    .pilot-card-grid { max-width: 1200px; margin: 24px auto 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 22px; }
    .pilot-card { min-height: 410px; padding: 22px; border-radius: 26px; border: 1px solid rgba(0, 212, 255, 0.24); background: linear-gradient(180deg, rgba(11, 20, 36, 0.96), rgba(8, 14, 24, 0.98)); display: grid; grid-template-rows: auto auto 1fr auto; gap: 14px; text-align: left; box-shadow: 0 18px 36px rgba(0, 0, 0, 0.24); transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease; }
    .pilot-card:hover { transform: translateY(-5px); box-shadow: 0 24px 44px rgba(0, 0, 0, 0.32); border-color: rgba(143, 220, 255, 0.36); }
    .pilot-card.locked-slot { opacity: 0.72; border-color: rgba(255, 211, 106, 0.18); }
    .pilot-card.open-slot { cursor: pointer; border-color: rgba(143, 220, 255, 0.42); }
    .pilot-card-crest { width: 86px; height: 86px; border-radius: 24px; display: flex; align-items: center; justify-content: center; font-size: 2.1rem; font-weight: 800; letter-spacing: 0.08em; background: linear-gradient(145deg, rgba(143, 220, 255, 0.18), rgba(255, 255, 255, 0.04)); border: 1px solid rgba(143, 220, 255, 0.22); color: #f1c46a; }
    .pilot-card-copy h3 { margin: 0 0 10px; font-size: 1.4rem; }
    .slot-tag { margin: 0 0 6px; text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.72rem; color: #8fdcff; }
    .card-level { background: rgba(112, 0, 255, 0.24); color: white; padding: 4px 10px; border-radius: 999px; font-size: 0.8rem; font-weight: bold; white-space: nowrap; }
    .pilot-card-stats p, .locked-copy p { margin: 6px 0; font-family: 'Consolas', monospace; color: rgba(255,255,255,0.78); }
    .pilot-card-actions { display: grid; grid-template-columns: 1fr; gap: 10px; margin-top: auto; }
    .slot-name-input { width: 100%; margin-top: 12px; padding: 12px 14px; border-radius: 12px; border: 1px solid rgba(143, 220, 255, 0.28); background: rgba(4, 12, 26, 0.9); color: white; }
    .starter-class-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; margin-top: 14px; }
    .starter-class-card { padding: 12px; border-radius: 14px; border: 1px solid rgba(255, 255, 255, 0.12); background: rgba(255, 255, 255, 0.04); color: white; display: grid; gap: 6px; text-align: left; }
    .starter-class-card span { font-size: 0.78rem; color: rgba(255, 255, 255, 0.72); line-height: 1.4; }
    .starter-class-card.selected { border-color: #f1ae56; background: rgba(241, 174, 86, 0.12); }
    .create-character-button { width: 100%; margin-top: 14px; border: none; border-radius: 999px; padding: 12px 16px; background: linear-gradient(90deg, #f1c46a, #f08b52); color: #1a1208; font-weight: 800; }
    .primary-action { margin-top: 0; }
    .secondary-action-button { border: 1px solid rgba(143, 220, 255, 0.28); background: rgba(255,255,255,0.04); color: white; border-radius: 999px; padding: 12px 16px; font-weight: 700; white-space: nowrap; }
