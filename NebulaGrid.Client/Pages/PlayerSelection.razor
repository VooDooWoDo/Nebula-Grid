    private double GetProjectedReserveProgressPercent(Player player, int previewMinutes)
    {
        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return 0;
        }

        var (projectedLevel, projectedXp) = GetProjectedReserveState(player, previewMinutes);
        return projectedLevel <= 0 ? 0 : Math.Clamp(projectedXp * 100d / (projectedLevel * 100d), 0, 100);
    }

