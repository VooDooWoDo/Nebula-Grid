    private string GetWeakSpotMode()
    {
        var creditsCoverage = GetFleetCoverageScore("credits");
        var fuelCoverage = GetFleetCoverageScore("fuel");
        var xpCoverage = GetFleetCoverageScore("xp");
        var reserveCoverage = GetFleetCoverageScore("reserve-growth");
        var weakestCoverage = Math.Min(Math.Min(creditsCoverage, fuelCoverage), Math.Min(xpCoverage, reserveCoverage));

        if (reserveCoverage == weakestCoverage)
        {
            return "reserve-growth";
        }

        if (xpCoverage == weakestCoverage)
        {
            return "xp";
        }

        if (fuelCoverage == weakestCoverage)
        {
            return "fuel";
        }

        return "credits";
    }

    private double GetFleetCoverageScore(string mode)
    {
        var classedPilotCount = Math.Max(1, slots.Count(slot => slot.Player is not null && !string.IsNullOrWhiteSpace(slot.Player.PilotClass)));
        var topPilot = GetTopPickPilot(mode);
        if (topPilot is null)
        {
            return 0;
        }

        return mode switch
        {
            "fuel" => (double)GetFleetPreviewFuel() / Math.Max(1, GetPreviewSummary(topPilot, previewWindowMinutes).Fuel * classedPilotCount),
            "xp" => (double)GetFleetPreviewPlayerXp() / Math.Max(1, GetPreviewSummary(topPilot, previewWindowMinutes).PlayerXp * classedPilotCount),
            "reserve-growth" => GetFleetProjectedReserveLevels() > 0
                ? (double)GetFleetProjectedReserveLevels() / Math.Max(1, GetProjectedReserveLevelsGained(topPilot) * classedPilotCount)
                : (double)slots.Where(slot => slot.Player is not null).Sum(slot => GetProjectedReservePriorityScore(slot.Player!)) / Math.Max(1, GetProjectedReservePriorityScore(topPilot) * classedPilotCount),
            _ => (double)GetFleetPreviewCredits() / Math.Max(1, GetPreviewSummary(topPilot, previewWindowMinutes).Credits * classedPilotCount)
        };
    }

