    private string GetAllRoundTimeShiftNote()
    {
        var currentPilot = GetAllRoundPilot();
        if (currentPilot is null)
        {
            return "Time shift: no all-round forecast yet";
        }

        var oneHourPilot = GetAllRoundPilot(60);
        var eightHourPilot = GetAllRoundPilot(480);
        var dayPilot = GetAllRoundPilot(1440);

        var sameAcrossWindows = oneHourPilot?.PlayerID == currentPilot.PlayerID
            && eightHourPilot?.PlayerID == currentPilot.PlayerID
            && dayPilot?.PlayerID == currentPilot.PlayerID;

        if (sameAcrossWindows)
        {
            return "Time shift: stays strongest from 1h to 24h";
        }

        var changes = new List<string>();
        if (oneHourPilot is not null && oneHourPilot.PlayerID != currentPilot.PlayerID)
        {
            changes.Add($"1h favors {oneHourPilot.PlayerName}");
        }

        if (eightHourPilot is not null && eightHourPilot.PlayerID != currentPilot.PlayerID)
        {
            changes.Add($"8h favors {eightHourPilot.PlayerName}");
        }

        if (dayPilot is not null && dayPilot.PlayerID != currentPilot.PlayerID)
        {
            changes.Add($"24h favors {dayPilot.PlayerName}");
        }

        return changes.Count == 0
            ? "Time shift: current window is the main differentiator"
            : $"Time shift: {string.Join(" | ", changes)}";
    }

