    .modal-close { border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.04); color: white; border-radius: 999px; padding: 10px 14px; }
    .modal-input { margin-top: 8px; }
    .modal-class-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }

    @@media (max-width: 720px) {
        .hangar-summary-head { flex-direction: column; }
        .hangar-actions { width: 100%; flex-direction: column; }
        .hangar-actions button { width: 100%; }
        .starter-class-grid { grid-template-columns: 1fr; }
        .modal-class-grid { grid-template-columns: 1fr; }
    }
</style>
