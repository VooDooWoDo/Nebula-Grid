        var buildingKey = jobKey switch
        {
            "hauling" => "freight-depot",
            "reactor" => "reactor-annex",
            _ => "survey-office"
        };

        return buildings.FirstOrDefault(building => string.Equals(building.BuildingKey, buildingKey, StringComparison.OrdinalIgnoreCase))?.Level ?? 0;
    }

    private OfflinePreviewSummary GetPreviewSummary(Player player, int previewMinutes)
    {
        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return new OfflinePreviewSummary();
        }

        var jobKey = GetNormalizedPassiveJobKey(player.PassiveJobKey, player.PilotClass);
        var buildingLevel = GetBuildingLevel(player.PlayerID, jobKey);

        return jobKey switch
        {
            "hauling" => BuildHaulingPreview(player, previewMinutes, buildingLevel),
            "reactor" => BuildReactorPreview(player, previewMinutes, buildingLevel),
            _ => BuildSurveyPreview(player, previewMinutes, buildingLevel)
        };
    }

    private bool IsBestCreditPilot(Player player)
    {
        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return false;
        }

        var maxCredits = slots.Where(slot => slot.Player is not null)
            .Select(slot => GetPreviewSummary(slot.Player!, previewWindowMinutes).Credits)
            .DefaultIfEmpty()
            .Max();

        var playerCredits = GetPreviewSummary(player, previewWindowMinutes).Credits;
        return playerCredits > 0 && playerCredits == maxCredits;
    }

    private bool IsBestFuelPilot(Player player)
    {
        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return false;
        }

        var maxFuel = slots.Where(slot => slot.Player is not null)
            .Select(slot => GetPreviewSummary(slot.Player!, previewWindowMinutes).Fuel)
            .DefaultIfEmpty()
            .Max();

        var playerFuel = GetPreviewSummary(player, previewWindowMinutes).Fuel;
        return playerFuel > 0 && playerFuel == maxFuel;
    }

    private bool IsBestXpPilot(Player player)
    {
        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return false;
        }

        var maxPlayerXp = slots.Where(slot => slot.Player is not null)
            .Select(slot => GetPreviewSummary(slot.Player!, previewWindowMinutes).PlayerXp)
            .DefaultIfEmpty()
            .Max();

        var playerXp = GetPreviewSummary(player, previewWindowMinutes).PlayerXp;
        return playerXp > 0 && playerXp == maxPlayerXp;
    }

    private bool IsBestReserveXpPilot(Player player)
    {
        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return false;
        }

        var maxReserveXp = slots.Where(slot => slot.Player is not null)
            .Select(slot => GetPreviewSummary(slot.Player!, previewWindowMinutes).ReserveXp)
            .DefaultIfEmpty()
            .Max();

        var reserveXp = GetPreviewSummary(player, previewWindowMinutes).ReserveXp;
        return reserveXp > 0 && reserveXp == maxReserveXp;
    }

    private bool IsBestReserveGrowthPilot(Player player)
    {
        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return false;
        }

        var maxLevels = slots.Where(slot => slot.Player is not null)
            .Select(slot => GetProjectedReserveLevelsGained(slot.Player!))
            .DefaultIfEmpty()
            .Max();

        var projectedLevels = GetProjectedReserveLevelsGained(player);
        return projectedLevels > 0 && projectedLevels == maxLevels;
    }

    private Player? GetBestReserveGrowthPilot()
    {
        return slots.Where(slot => slot.Player is not null)
            .Select(slot => slot.Player!)
            .Where(player => GetProjectedReserveLevelsGained(player) > 0)
            .OrderByDescending(GetProjectedReserveLevelsGained)
            .ThenByDescending(GetProjectedReservePriorityScore)
            .ThenBy(player => player.PlayerName)
            .FirstOrDefault();
    }

    private Player? GetBestNextReservePilot()
    {
        return slots.Where(slot => slot.Player is not null)
            .Select(slot => slot.Player!)
            .Where(player => !string.IsNullOrWhiteSpace(player.PilotClass))
            .OrderByDescending(GetProjectedReservePriorityScore)
            .ThenBy(player => player.PlayerName)
            .FirstOrDefault();
    }

    private bool IsBestNextReservePilot(Player player)
    {
        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return false;
        }

        var maxPriority = slots.Where(slot => slot.Player is not null)
            .Select(slot => GetProjectedReservePriorityScore(slot.Player!))
            .DefaultIfEmpty()
            .Max();

        var priority = GetProjectedReservePriorityScore(player);
        return priority > 0 && priority == maxPriority;
    }

    private bool HasProjectedReserveLevelUp(Player player) => GetProjectedReserveLevelsGained(player) > 0;

    private bool IsProjectedReserveNearLevelUp(Player player)
    {
        return !HasProjectedReserveLevelUp(player) && GetProjectedReserveProgressPercent(player) >= 85;
    }

    private string GetReserveGrowthPanelClass(Player player)
    {
        if (HasProjectedReserveLevelUp(player))
        {
            return "growth-hit";
        }

        return IsProjectedReserveNearLevelUp(player) ? "growth-soon" : string.Empty;
    }

    private string GetReserveGrowthFillClass(Player player)
    {
        if (HasProjectedReserveLevelUp(player))
        {
            return "growth-hit";
        }

        return IsProjectedReserveNearLevelUp(player) ? "growth-soon" : string.Empty;
    }

    private int GetProjectedReserveLevelsGained(Player player)
    {
        return GetProjectedReserveLevelsGained(player, previewWindowMinutes);
    }

    private int GetProjectedReserveLevelsGained(Player player, int previewMinutes)
    {
        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return 0;
        }

        var preview = GetPreviewSummary(player, previewMinutes);
        if (preview.ReserveXp <= 0)
        {
            return 0;
        }

        var projectedLevel = Math.Max(1, player.Level);
        var projectedXp = Math.Max(0, player.XP) + preview.ReserveXp;
        var levelsGained = 0;

        while (projectedXp >= projectedLevel * 100)
        {
            projectedXp -= projectedLevel * 100;
            projectedLevel++;
            levelsGained++;
        }

        return levelsGained;
    }

    private int GetProjectedReservePriorityScore(Player player)
    {
        return GetProjectedReservePriorityScore(player, previewWindowMinutes);
    }

    private int GetProjectedReservePriorityScore(Player player, int previewMinutes)
    {
        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return 0;
        }

        var levelsGained = GetProjectedReserveLevelsGained(player, previewMinutes);
        var progressPercent = (int)Math.Round(GetProjectedReserveProgressPercent(player, previewMinutes) * 10, MidpointRounding.AwayFromZero);
        return (levelsGained * 10000) + progressPercent;
    }

    private (int Level, int Xp) GetProjectedReserveState(Player player)
    {
        return GetProjectedReserveState(player, previewWindowMinutes);
    }

    private (int Level, int Xp) GetProjectedReserveState(Player player, int previewMinutes)
    {
        var projectedLevel = Math.Max(1, player.Level);
        var projectedXp = Math.Max(0, player.XP);

        if (string.IsNullOrWhiteSpace(player.PilotClass))
        {
            return (projectedLevel, projectedXp);
        }

        var preview = GetPreviewSummary(player, previewMinutes);
        projectedXp += preview.ReserveXp;

        while (projectedXp >= projectedLevel * 100)
        {
            projectedXp -= projectedLevel * 100;
            projectedLevel++;
        }

        return (projectedLevel, projectedXp);
    }

    private static OfflinePreviewSummary BuildSurveyPreview(Player player, int previewMinutes, int buildingLevel)
    {
        var creditsPerMinute = 5 + player.Level + (player.MiningSkillLevel * 2) + (player.MiningTreeLevel * 4) + (buildingLevel * 3);
        var credits = previewMinutes * creditsPerMinute;
        var reserveXp = Math.Max(1, previewMinutes / 20) * (1 + player.MiningSkillLevel + player.MiningTreeLevel + buildingLevel);
        return new OfflinePreviewSummary
        {
            Credits = credits,
            ReserveXp = reserveXp
        };
    }

    private static OfflinePreviewSummary BuildHaulingPreview(Player player, int previewMinutes, int buildingLevel)
    {
        var convoyCycles = Math.Max(1, previewMinutes / 18);
        var fuelPerCycle = 1 + (player.Level / 3) + player.LogisticsSkillLevel + (player.LogisticsTreeLevel * 2) + buildingLevel;
        var fuel = convoyCycles * fuelPerCycle;
        var reserveXp = Math.Max(1, previewMinutes / 25) * (1 + player.LogisticsSkillLevel + player.LogisticsTreeLevel + buildingLevel);
        return new OfflinePreviewSummary
        {
            Fuel = fuel,
            ReserveXp = reserveXp
        };
    }

    private static OfflinePreviewSummary BuildReactorPreview(Player player, int previewMinutes, int buildingLevel)
    {
        var drillCycles = Math.Max(1, previewMinutes / 12);
        var playerXp = drillCycles * (1 + (player.Level / 2) + player.ReactorSkillLevel + (player.ReactorTreeLevel * 2) + (buildingLevel * 2));
        var reserveXp = playerXp + (drillCycles * (1 + player.ReactorSkillLevel + buildingLevel));
        return new OfflinePreviewSummary
        {
            PlayerXp = playerXp,
            ReserveXp = reserveXp
        };
    }

    private static string GetNormalizedPassiveJobKey(string? passiveJobKey, string? pilotClass) => string.IsNullOrWhiteSpace(passiveJobKey)
        ? GetDefaultPassiveJobKey(pilotClass)
        : passiveJobKey.Trim().ToLowerInvariant();

    private static string GetDefaultPassiveJobKey(string? pilotClass) => (pilotClass ?? string.Empty).Trim() switch
    {
        "Quartermaster" => "hauling",
        "Vanguard" => "reactor",
        _ => "survey"
    };

    private void HandleSlotClick(CharacterSlotSummary slot)
    {
        if (slot.Player is null && slot.IsUnlocked)
        {
            OpenCreateCharacterModal(slot.SlotId);
        }
    }

    private void OpenCreateCharacterModal(int slotId)
    {
        if (!drafts.ContainsKey(slotId))
        {
            drafts[slotId] = new CharacterDraft();
        }

        activeCreateSlotId = slotId;
        isCreateModalOpen = true;
        loadError = null;
    }

    private void CloseCreateCharacterModal()
    {
        isCreateModalOpen = false;
        activeCreateSlotId = null;
    }

    private static string GetSlotVisual(CharacterSlotSummary slot)
    {
        if (slot.Player is null)
        {
            return slot.IsUnlocked ? "+" : "LOCK";
        }

        return slot.Player.PilotClass switch
        {
            "Prospector" => "⛏",
            "Quartermaster" => "⛴",
            "Vanguard" => "⚡",
            _ => "CORE"
        };
    }
}

