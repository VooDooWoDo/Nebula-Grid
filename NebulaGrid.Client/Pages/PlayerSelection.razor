    private async Task ToggleAutoOptimizeHangarAsync(ChangeEventArgs args)
    {
        autoOptimizeHangar = args.Value switch
        {
            bool boolValue => boolValue,
            string stringValue when bool.TryParse(stringValue, out var parsed) => parsed,
            _ => false
        };

        await JSRuntime.InvokeVoidAsync("nebulaStorage.set", AutoOptimizeHangarKey, autoOptimizeHangar.ToString().ToLowerInvariant());

        if (autoOptimizeHangar)
        {
            OptimizeReserveView();
        }
    }

