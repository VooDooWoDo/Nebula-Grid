            .OrderBy(slot => slot.Player is null ? 1 : 0)
            .ThenByDescending(slot => slot.Player is not null ? GetCurrentFocusValue(slot.Player) : int.MinValue)
            .ThenBy(slot => slot.Player is null ? (slot.IsUnlocked ? 0 : 1) : 0)
            .ThenBy(slot => slot.SlotId);
    }

    private int? GetPilotFocusRank(Player player)
    {
        var rankedPlayers = slots.Where(slot => slot.Player is not null)
            .Select(slot => slot.Player!)
            .OrderByDescending(GetCurrentFocusValue)
            .ThenByDescending(pilot => pilot.Level)
            .ThenBy(pilot => pilot.PlayerName)
            .ToList();

        var playerValue = GetCurrentFocusValue(player);
        if (playerValue <= 0)
        {
            return null;
        }

        var index = rankedPlayers.FindIndex(pilot => pilot.PlayerID == player.PlayerID);
        return index >= 0 ? index + 1 : null;
    }

