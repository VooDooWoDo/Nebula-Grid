        var runnerProgress = GetProjectedReserveProgressPercent(runnerUp);
        return $"Lead margin: {(leaderProgress - runnerProgress).ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)}% closer than {runnerUp.PlayerName}";
