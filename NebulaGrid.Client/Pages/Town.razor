@page "/town"
@using System.Net.Http.Json
@using NebulaGrid.Shared.Models
@using NebulaGrid.Shared.Services
@inject HttpClient HttpClient
@inject PlayerService PlayerService
@inject GameStatus Status
@implements IDisposable

<PageTitle>Frontier Hub - Nebula Grid</PageTitle>

@if (!PlayerService.IsAreaUnlocked("town"))
{
    <div class="town-shell">
        <div class="town-lock-card">
            <h2>Frontier Hub locked</h2>
            <p>@PlayerService.GetUnlockText("town").</p>
        </div>
    </div>
}
else
{
    <div class="town-shell">
        <section class="town-header">
            <div>
                <p class="town-eyebrow">Frontier Hub</p>
                <h1>Build the city behind your idle roster</h1>
                <p class="town-lede">Each district unlocks or amplifies idle duties. Ship Upgrade boosts flying income, Garden Upgrade powers gardening routes, and Better Loot Box strengthens gambling XP loops.</p>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <div class="town-status">@statusMessage</div>
        }

        <section class="reserve-jobs-panel">
            <div class="reserve-jobs-header">
                <div>
                    <p class="town-eyebrow">Reserve Jobs</p>
                    <h2>Assign the pilot's idle duty</h2>
                    <p class="town-lede">Set which background route this pilot should run while you are offline. Town districts unlock stronger reserve work.</p>
                </div>
                <div class="reserve-active-card">
                    <span>Active Duty</span>
                    <strong>@GetPassiveJobTitle(PlayerService.PassiveJobKey)</strong>
                    <small>@GetPassiveJobSubtitle(PlayerService.PassiveJobKey)</small>
                    <small class="reserve-active-note">Reserve Pilot XP levels your inactive pilots on this account, not the account itself.</small>
                </div>
            </div>

            <div class="reserve-job-grid">
                @foreach (var job in reserveJobs)
                {
                    var unlocked = PlayerService.IsReserveJobUnlocked(job.Key);
                    var isActive = string.Equals(NormalizePassiveJobKey(PlayerService.PassiveJobKey), job.Key, StringComparison.OrdinalIgnoreCase);
                    <article class="reserve-job-card @(unlocked ? "online" : "locked") @(isActive ? "active" : string.Empty)">
                        <div class="reserve-job-head">
                            <div>
                                <span class="reserve-job-tag">@job.Tag</span>
                                <h3>@job.Title</h3>
                                <p>@job.Description</p>
                            </div>
                            <div class="reserve-job-icon">@job.Icon</div>
                        </div>

                        <div class="reserve-job-meta">
                            <span>@job.BonusText(GetBuildingLevelForJob(job.Key))</span>
                            <span class="reserve-job-preview">@GetPassiveJobPreview(job.Key)</span>
                            <span>@(unlocked ? "Unlocked and ready." : PlayerService.GetReserveJobUnlockText(job.Key))</span>
                        </div>

                        <button class="town-upgrade reserve-job-button"
                                disabled="@(!unlocked || isActive || isSwitchingPassiveJob)"
                                @onclick="() => SetPassiveJobAsync(job.Key)">
                            @(isActive ? "Active" : isSwitchingPassiveJob ? "Switching..." : $"Assign {job.Title}")
                        </button>
                    </article>
                }
            </div>

            <p class="reserve-jobs-note">Reserve Pilot XP is stored on your offline roster pilots. Higher reserve pilot levels make later idle jobs stronger.</p>
        </section>

        <div class="town-grid">
            @foreach (var building in buildings)
            {
                var nextLevel = building.Level + 1;
                var isMaxed = building.Level >= 5;
                var missingResources = PlayerService.Resource1 < building.CreditCost || PlayerService.Alloy < building.AlloyCost;
                var canUpgrade = !isMaxed && !missingResources;
                <article class="town-card @(building.Level > 0 ? "online" : "offline")">
                    <div class="town-card-head">
                        <div>
                            <span class="town-tag">@building.Tag</span>
                            <h2>@building.Title</h2>
                            <p>@building.Description</p>
                        </div>
                        <div class="town-level">LVL @building.Level</div>
                    </div>

                    <div class="town-effects">
                        <span>@building.UnlockText(building.Level)</span>
                        <span>@building.BonusText(building.Level)</span>
                    </div>

                    <div class="town-requirement @(canUpgrade ? "ready" : "locked")">
                        @if (isMaxed)
                        {
                            <span>District fully established.</span>
                        }
                        else if (missingResources)
                        {
                            <span>Need @building.CreditCost Credits and @building.AlloyCost Alloy for the next district tier.</span>
                        }
                        else
                        {
                            <span>Ready to upgrade to LVL @nextLevel.</span>
                        }
                    </div>

                    <button class="town-upgrade"
                title="@(isMaxed ? "This district is already maxed." : string.Empty)"
                            disabled="@(!canUpgrade)"
                            @onclick="() => UpgradeBuildingAsync(building.Key)">
                        @(isMaxed ? "Maxed" : $"Upgrade ({building.CreditCost} Credits / {building.AlloyCost} Alloy)")
                    </button>
                </article>
            }
        </div>
    </div>
}

@code {
    private readonly List<TownBuildingViewModel> buildings = new();
    private readonly List<ReserveJobViewModel> reserveJobs = new();
    private string? statusMessage;
    private int hydratedPlayerId;
    private bool isSwitchingPassiveJob;

    protected override async Task OnInitializedAsync()
    {
        Status.OnResourceChanged += HandleResourceChanged;
        InitializeBuildings();
        InitializeReserveJobs();
        await EnsureLoadedAsync();
    }

    private async Task EnsureLoadedAsync()
    {
        if (PlayerService.SelectedPlayerId <= 0 || hydratedPlayerId == PlayerService.SelectedPlayerId)
        {
            return;
        }

        hydratedPlayerId = PlayerService.SelectedPlayerId;
        await LoadTownAsync();
    }

    private void InitializeBuildings()
    {
        if (buildings.Count > 0)
        {
            return;
        }

        buildings.Add(new TownBuildingViewModel
        {
            Key = "ship-upgrade",
            Tag = "Economy",
            Title = "Ship Upgrade",
            Description = "Keeps reserve pilots flying profitable asteroid routes between active sessions.",
            UnlockText = level => level > 0 ? "Flying Duty unlocked" : "Unlocks Flying Duty",
            BonusText = level => level > 0
                ? $"Game2 collection boost: +{level * 12}% resources"
                : "Game2 collection boost: +0% resources"
        });
        buildings.Add(new TownBuildingViewModel
        {
            Key = "garden-upgrade",
            Tag = "Logistics",
            Title = "Garden Upgrade",
            Description = "Supports reserve gardeners on side-routes that return with stable fuel convoys.",
            UnlockText = level => level > 0 ? "Gardening Duty unlocked" : "Unlocks Gardening Duty",
            BonusText = level => level > 0
                ? $"Bio Dome harvest boost: +{level * 15}% biomass"
                : "Bio Dome harvest boost: +0% biomass"
        });
        buildings.Add(new TownBuildingViewModel
        {
            Key = "better-loot-box",
            Tag = "Training",
            Title = "Better Loot Box",
            Description = "Lets reserve gamblers run controlled risk cycles that feed player and reserve pilot XP.",
            UnlockText = level => level > 0 ? "Gambling Duty unlocked" : "Unlocks Gambling Duty",
            BonusText = level => level > 0
                ? $"Stellar Cargo reward boost: +{level * 10}% drops"
                : "Stellar Cargo reward boost: +0% drops"
        });
    }

    private void InitializeReserveJobs()
    {
        if (reserveJobs.Count > 0)
        {
            return;
        }

        reserveJobs.Add(new ReserveJobViewModel
        {
            Key = "flying",
            Tag = "Economy",
            Title = "Flying Duty",
            Icon = "🚀",
            Description = "Reserve pilots fly side belts and bring back passive credit income.",
            BonusText = level => level > 0 ? $"Ship Upgrade LVL {level}: stronger flying income and reserve pilot XP." : "Requires Ship Upgrade LVL 1."
        });
        reserveJobs.Add(new ReserveJobViewModel
        {
            Key = "gardening",
            Tag = "Logistics",
            Title = "Gardening Duty",
            Icon = "🌱",
            Description = "Gardeners run growth loops and return with fuel caches while you are offline.",
            BonusText = level => level > 0 ? $"Garden Upgrade LVL {level}: larger fuel routes and growth XP." : "Requires Garden Upgrade LVL 1."
        });
        reserveJobs.Add(new ReserveJobViewModel
        {
            Key = "gambling",
            Tag = "Training",
            Title = "Gambling Duty",
            Icon = "🎲",
            Description = "Gamblers perform controlled risk cycles that feed player XP and reserve pilot growth.",
            BonusText = level => level > 0 ? $"Better Loot Box LVL {level}: more player XP and reserve pilot XP." : "Requires Better Loot Box LVL 1."
        });
    }

    private async Task LoadTownAsync()
    {
        if (PlayerService.SelectedPlayerId <= 0)
        {
            statusMessage = "Choose an active pilot account first.";
            hydratedPlayerId = 0;
            return;
        }

        try
        {
            var townBuildings = await HttpClient.GetFromJsonAsync<List<PlayerTownBuilding>>($"api/game/player/{PlayerService.SelectedPlayerId}/town") ?? new List<PlayerTownBuilding>();
            var player = await HttpClient.GetFromJsonAsync<Player>($"api/game/player/{PlayerService.SelectedPlayerId}");

            if (player is not null)
            {
                PlayerService.UpdateFromPlayer(player);
                statusMessage = player.OfflineSummary;
            }

            PlayerService.UpdateTownBuildings(townBuildings);

            foreach (var building in buildings)
            {
                building.Level = townBuildings.FirstOrDefault(x => string.Equals(NormalizeTownBuildingKey(x.BuildingKey), building.Key, StringComparison.OrdinalIgnoreCase))?.Level ?? 0;
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Town could not be loaded: {ex.Message}";
        }
    }

    private async Task UpgradeBuildingAsync(string buildingKey)
    {
        var response = await HttpClient.PostAsync($"api/game/player/{PlayerService.SelectedPlayerId}/town/upgrade/{buildingKey}", null);
        if (!response.IsSuccessStatusCode)
        {
            statusMessage = await response.Content.ReadAsStringAsync();
            return;
        }

        var updatedBuildings = await response.Content.ReadFromJsonAsync<List<PlayerTownBuilding>>() ?? new List<PlayerTownBuilding>();
        var player = await HttpClient.GetFromJsonAsync<Player>($"api/game/player/{PlayerService.SelectedPlayerId}");
        if (player is not null)
        {
            PlayerService.UpdateFromPlayer(player);
        }

        PlayerService.UpdateTownBuildings(updatedBuildings);
        foreach (var building in buildings)
        {
            building.Level = updatedBuildings.FirstOrDefault(x => string.Equals(NormalizeTownBuildingKey(x.BuildingKey), building.Key, StringComparison.OrdinalIgnoreCase))?.Level ?? 0;
        }

        var upgradedBuilding = buildings.First(x => x.Key == buildingKey);
        var xpGain = 12 + (upgradedBuilding.Level * 6);
        PlayerService.AddXP(xpGain);
        var playerSaveResponse = await HttpClient.PostAsJsonAsync("api/game/saveplayer", PlayerService.ToPlayer());
        playerSaveResponse.EnsureSuccessStatusCode();
        await RefreshAccountProgressAsync();

        statusMessage = $"{upgradedBuilding.Title} upgraded. +{xpGain} XP.";
        Status.NotifyResourceChanged();
    }

    private async Task SetPassiveJobAsync(string jobKey)
    {
        if (isSwitchingPassiveJob || PlayerService.SelectedPlayerId <= 0)
        {
            return;
        }

        if (!PlayerService.IsReserveJobUnlocked(jobKey))
        {
            statusMessage = PlayerService.GetReserveJobUnlockText(jobKey);
            return;
        }

        isSwitchingPassiveJob = true;

        try
        {
            PlayerService.PassiveJobKey = jobKey;
            var saveResponse = await HttpClient.PostAsJsonAsync("api/game/saveplayer", PlayerService.ToPlayer());
            saveResponse.EnsureSuccessStatusCode();
            statusMessage = $"Reserve duty changed to {GetPassiveJobTitle(jobKey)}.";
            Status.NotifyResourceChanged();
        }
        catch (Exception ex)
        {
            statusMessage = $"Reserve duty could not be changed: {ex.Message}";
        }
        finally
        {
            isSwitchingPassiveJob = false;
        }
    }

    private async Task RefreshAccountProgressAsync()
    {
        if (PlayerService.AccountProfileId <= 0)
        {
            return;
        }

        var account = await HttpClient.GetFromJsonAsync<AccountProfile>($"api/game/account/{PlayerService.AccountProfileId}");
        if (account is not null)
        {
            PlayerService.UpdateAccount(account);
        }
    }

    private int GetBuildingLevelForJob(string jobKey) => jobKey switch
    {
        "gardening" => PlayerService.FreightDepotLevel,
        "gambling" => PlayerService.ReactorAnnexLevel,
        _ => PlayerService.SurveyOfficeLevel
    };

    private static string GetPassiveJobTitle(string? jobKey) => NormalizePassiveJobKey(jobKey) switch
    {
        "gardening" => "Gardening Duty",
        "gambling" => "Gambling Duty",
        _ => "Flying Duty"
    };

    private static string GetPassiveJobSubtitle(string? jobKey) => NormalizePassiveJobKey(jobKey) switch
    {
        "gardening" => "Fuel-focused reserve route",
        "gambling" => "XP-focused reserve route",
        _ => "Credit-focused reserve route"
    };

    private string GetPassiveJobPreview(string jobKey)
    {
        if (string.IsNullOrWhiteSpace(PlayerService.PilotClass))
        {
            return "Preview unavailable until the pilot locks in a class.";
        }

        const int previewMinutes = 60;
        var buildingLevel = GetBuildingLevelForJob(jobKey);

        return jobKey switch
        {
            "gardening" => GetHaulingPreview(previewMinutes, buildingLevel),
            "gambling" => GetReactorPreview(previewMinutes, buildingLevel),
            _ => GetSurveyPreview(previewMinutes, buildingLevel)
        };
    }

    private static string NormalizePassiveJobKey(string? jobKey)
    {
        var normalized = (jobKey ?? string.Empty).Trim().ToLowerInvariant();
        return normalized switch
        {
            "survey" => "flying",
            "hauling" => "gardening",
            "reactor" => "gambling",
            _ => normalized
        };
    }

    private static string NormalizeTownBuildingKey(string? buildingKey)
    {
        var normalized = (buildingKey ?? string.Empty).Trim().ToLowerInvariant();
        return normalized switch
        {
            "survey-office" => "ship-upgrade",
            "freight-depot" => "garden-upgrade",
            "reactor-annex" => "better-loot-box",
            _ => normalized
        };
    }

    private string GetSurveyPreview(int previewMinutes, int buildingLevel)
    {
        var creditsPerMinute = 5 + PlayerService.CurrentLevel + (PlayerService.PilotMiningSkill * 2) + (PlayerService.PilotMiningTreeLevel * 4) + (buildingLevel * 3);
        var credits = previewMinutes * creditsPerMinute;
        var reserveXp = Math.Max(1, previewMinutes / 20) * (1 + PlayerService.PilotMiningSkill + PlayerService.PilotMiningTreeLevel + buildingLevel);
        return $"Preview 60m: +{credits} Credits, +{reserveXp} reserve pilot XP.";
    }

    private string GetHaulingPreview(int previewMinutes, int buildingLevel)
    {
        var convoyCycles = Math.Max(1, previewMinutes / 18);
        var fuelPerCycle = 1 + (PlayerService.CurrentLevel / 3) + PlayerService.PilotLogisticsSkill + (PlayerService.PilotLogisticsTreeLevel * 2) + buildingLevel;
        var fuel = convoyCycles * fuelPerCycle;
        var reserveXp = Math.Max(1, previewMinutes / 25) * (1 + PlayerService.PilotLogisticsSkill + PlayerService.PilotLogisticsTreeLevel + buildingLevel);
        return $"Preview 60m: +{fuel} Fuel, +{reserveXp} reserve pilot XP.";
    }

    private string GetReactorPreview(int previewMinutes, int buildingLevel)
    {
        var drillCycles = Math.Max(1, previewMinutes / 12);
        var playerXp = drillCycles * (1 + (PlayerService.CurrentLevel / 2) + PlayerService.PilotReactorSkill + (PlayerService.PilotReactorTreeLevel * 2) + (buildingLevel * 2));
        var reserveXp = playerXp + (drillCycles * (1 + PlayerService.PilotReactorSkill + buildingLevel));
        return $"Preview 60m: +{playerXp} player XP, +{reserveXp} reserve pilot XP.";
    }

    private async void HandleResourceChanged()
    {
        try
        {
            await EnsureLoadedAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Town resource handler failed: {ex.Message}");
        }
    }

    public void Dispose()
    {
        Status.OnResourceChanged -= HandleResourceChanged;
    }

    private sealed class TownBuildingViewModel
    {
        public string Key { get; set; } = string.Empty;
        public string Tag { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public int Level { get; set; }
        public Func<int, string> UnlockText { get; set; } = _ => string.Empty;
        public Func<int, string> BonusText { get; set; } = _ => string.Empty;

        public int CreditCost => Key switch
        {
            "ship-upgrade" => 700 * (Level + 1),
            "garden-upgrade" => 950 * (Level + 1),
            "better-loot-box" => 1200 * (Level + 1),
            _ => 800 * (Level + 1)
        };

        public int AlloyCost => Key switch
        {
            "ship-upgrade" => 6 * (Level + 1),
            "garden-upgrade" => 10 * (Level + 1),
            "better-loot-box" => 14 * (Level + 1),
            _ => 8 * (Level + 1)
        };
    }

    private sealed class ReserveJobViewModel
    {
        public string Key { get; set; } = string.Empty;
        public string Tag { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Icon { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public Func<int, string> BonusText { get; set; } = _ => string.Empty;
    }
}

