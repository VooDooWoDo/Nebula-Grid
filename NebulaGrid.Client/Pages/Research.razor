@page "/research"
@using NebulaGrid.Shared.Services
@inject PlayerService PlayerService

<PageTitle>Research Lab - Nebula Grid</PageTitle>

@if (!PlayerService.IsAreaUnlocked("research"))
{
    <div class="research-shell">
        <div class="status-banner">Research Lab is locked. @PlayerService.GetUnlockText("research"). Current Pilot Level: @PlayerService.CurrentLevel.</div>
    </div>
}
else
{

<div class="research-shell">
    <div class="research-header">
        <div>
            <p class="eyebrow">Research Lab</p>
            <h1>Research upgrades temporarily offline</h1>
            <p class="lede">Upgrade nodes are removed for now while new research paths are being redesigned.</p>
        </div>
        <div class="research-side-panels">
            <div class="fuel-panel">
                <span>Available Fuel</span>
                <strong>@PlayerService.Resource2</strong>
            </div>
            <div class="fuel-panel biomass-panel">
                <span>Available Biomass</span>
                <strong>@PlayerService.Biomass</strong>
            </div>
            <div class="xp-panel">
                <span>Pilot Progress</span>
                <strong>LVL @PlayerService.CurrentLevel</strong>
                <small>@PlayerService.CurrentXP / @GetXpThreshold() XP</small>
                <div class="xp-track">
                    <div class="xp-fill" style="width: @GetXpPercent().ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="status-banner">All research upgrades are currently disabled. You can still use Fuel and Biomass in other systems.</div>
</div>

}

<style>
    .research-shell {
        min-height: calc(100vh - 120px);
        padding: 32px;
        color: #f4f0e8;
        background:
            radial-gradient(circle at top left, rgba(220, 140, 42, 0.2), transparent 30%),
            radial-gradient(circle at bottom right, rgba(0, 122, 145, 0.22), transparent 28%),
            linear-gradient(145deg, #09131a, #121a25 55%, #1d1610);
    }

    .research-header {
        display: flex;
        justify-content: space-between;
        gap: 24px;
        align-items: end;
        margin-bottom: 28px;
    }

    .research-side-panels {
        display: grid;
        gap: 14px;
        min-width: 220px;
    }

    .eyebrow {
        margin: 0 0 8px;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: #f1ae56;
        font-size: 0.78rem;
    }

    .research-header h1 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3.4rem);
        line-height: 1;
    }

    .lede {
        max-width: 720px;
        color: rgba(244, 240, 232, 0.78);
    }

    .fuel-panel {
        min-width: 180px;
        padding: 18px 20px;
        border-radius: 18px;
        background: rgba(8, 20, 28, 0.82);
        border: 1px solid rgba(241, 174, 86, 0.32);
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.25);
    }

    .fuel-panel span {
        display: block;
        color: rgba(244, 240, 232, 0.65);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.72rem;
    }

    .fuel-panel strong {
        display: block;
        margin-top: 8px;
        font-size: 2rem;
        color: #f1ae56;
    }

    .biomass-panel {
        border-color: rgba(146, 255, 198, 0.26);
    }

    .biomass-panel strong {
        color: #92ffc6;
    }

    .xp-panel {
        padding: 18px 20px;
        border-radius: 18px;
        background: rgba(8, 20, 28, 0.82);
        border: 1px solid rgba(125, 226, 255, 0.28);
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.25);
    }

    .xp-panel span,
    .xp-panel small {
        display: block;
        color: rgba(244, 240, 232, 0.68);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.72rem;
    }

    .xp-panel strong {
        display: block;
        margin-top: 8px;
        font-size: 1.35rem;
        color: #7de2ff;
    }

    .xp-panel small {
        margin-top: 8px;
        text-transform: none;
        letter-spacing: normal;
        font-size: 0.85rem;
    }

    .xp-track {
        margin-top: 10px;
        height: 8px;
        border-radius: 999px;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.12);
    }

    .xp-fill {
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #007a91, #7de2ff);
        transition: width 0.2s ease;
    }

    .status-banner {
        margin-bottom: 18px;
        padding: 12px 16px;
        border-radius: 14px;
        background: rgba(0, 122, 145, 0.18);
        border: 1px solid rgba(125, 226, 255, 0.28);
        color: #a8efff;
    }

    .research-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 18px;
    }

    .research-card {
        padding: 20px;
        border-radius: 22px;
        background: rgba(8, 20, 28, 0.82);
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 18px 32px rgba(0, 0, 0, 0.24);
    }

    .research-meta {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .research-tag {
        color: #7de2ff;
    }

    .research-level {
        color: #f1ae56;
    }

    .research-card h2 {
        margin: 0 0 10px;
    }

    .research-card p {
        margin: 0;
        color: rgba(244, 240, 232, 0.78);
        line-height: 1.5;
    }

    .research-effect {
        margin: 18px 0;
        color: #f1ae56;
        font-weight: 600;
    }

    .research-button {
        width: 100%;
        border: none;
        border-radius: 999px;
        padding: 12px 16px;
        background: linear-gradient(90deg, #f1ae56, #f56d3d);
        color: #15100a;
        font-weight: 700;
        cursor: pointer;
    }

    .research-button:disabled {
        cursor: not-allowed;
        opacity: 0.45;
    }

    @@media (max-width: 760px) {
        .research-shell {
            padding: 20px;
        }

        .research-header {
            flex-direction: column;
            align-items: stretch;
        }
    }
</style>

@code {
    private int GetXpThreshold() => Math.Max(100, PlayerService.CurrentLevel * 100);

    private double GetXpPercent()
    {
        var threshold = GetXpThreshold();
        return threshold <= 0 ? 0 : Math.Clamp(PlayerService.CurrentXP * 100d / threshold, 0, 100);
    }

}