@page "/lootbox"
@using System.Net.Http.Json
@using NebulaGrid.Shared.Services
@using NebulaGrid.Shared.Models
@inject PlayerService PlayerService
@inject NavigationManager NavManager
@inject GameStatus Status
@inject HttpClient Http
@implements IDisposable

@if (!PlayerService.IsAreaUnlocked("lootbox"))
{
    <div class="loot-container">
        <div class="loot-header">
            <h1>STELLAR CARGO</h1>
            <p>Stellar Cargo is locked. @PlayerService.GetUnlockText("lootbox"). Current Pilot Level: @PlayerService.CurrentLevel.</p>
        </div>
    </div>
}
else
{

<div class="loot-container">
    <div class="loot-header">
        <h1>STELLAR CARGO</h1>
        <p>Try your luck, Pilot! A container costs <strong>100 Credits</strong> and can drop Credits, Fuel, Alloy, Biomass, or XP from premium data caches. Better Loot Box upgrades increase all rewards.</p>
    </div>

    <div class="resource-bar">
        <span>Loot Bonus: <strong>+@(PlayerService.ReactorAnnexLevel * 10)%</strong></span>
    </div>

    <div class="box-display">
        <div class="box-visual @(isOpening ? "is-opening" : "")">
            @if (!isOpening && lastWinIcon != "")
            {
                <div class="win-reveal">@lastWinIcon</div>
            }
            else
            {
                <span>📦</span>
            }
        </div>

        <div class="message-box">
            @if (isOpening)
            {
                <div class="analysis-panel">
                    <span>@message</span>
                    <div class="analysis-track">
                        <div class="analysis-fill" style="width: @analysisProgress%"></div>
                    </div>
                </div>
            }
            else
            {
                @message
            }
        </div>

        <button class="btn-open" @onclick="OpenBox" disabled="@isOpening">
            @if (isOpening) { <span class="loader"></span> }
            else { <span>OPEN CONTAINER</span> }
        </button>
    </div>

    @if (recentWins.Any())
    {
        <div class="history">
            <h4>Recent Finds:</h4>
            <ul>
                @foreach (var win in recentWins)
                {
                    <li>@win</li>
                }
            </ul>
        </div>
    }
</div>

}

<style>
    .loot-container {
        max-width: 600px;
        margin: 20px auto;
        text-align: center;
        color: white;
        font-family: 'Segoe UI', sans-serif;
    }

    .loot-header h1 {
        color: #00d4ff;
        text-shadow: 0 0 10px rgba(0, 212, 255, 0.5);
        letter-spacing: 3px;
    }

    .box-display {
        background: rgba(15, 15, 35, 0.9);
        border: 2px solid #7000ff;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 0 30px rgba(112, 0, 255, 0.2);
    }

    .resource-bar {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 10px;
        margin-bottom: 16px;
        padding: 14px;
        border-radius: 14px;
        background: rgba(16, 20, 44, 0.76);
        border: 1px solid rgba(126, 176, 255, 0.18);
    }

    .resource-bar span {
        color: #a9c5ff;
        font-size: 0.95rem;
    }

    .resource-bar strong {
        color: #ffffff;
    }

    .box-visual {
        font-size: 100px;
        height: 150px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        transition: all 0.3s;
    }

    .win-reveal {
        animation: scaleIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .is-opening {
        animation: shake 0.15s infinite;
        filter: drop-shadow(0 0 20px #7000ff);
    }

    .message-box {
        height: 50px;
        font-size: 1.2rem;
        margin-bottom: 20px;
        color: #ffd700;
    }

    .analysis-panel {
        display: grid;
        gap: 10px;
    }

    .analysis-track {
        width: 100%;
        height: 8px;
        border-radius: 999px;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.12);
    }

    .analysis-fill {
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #7000ff, #00d4ff);
        transition: width 0.18s linear;
    }

    .btn-open {
        background: linear-gradient(135deg, #7000ff 0%, #00d4ff 100%);
        border: none;
        color: white;
        padding: 15px 40px;
        font-weight: bold;
        border-radius: 50px;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        width: 100%;
    }

    .btn-open:hover:not(:disabled) {
        transform: scale(1.05);
        box-shadow: 0 0 20px rgba(0, 212, 255, 0.6);
    }

    .btn-open:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .history {
        margin-top: 30px;
        background: rgba(0, 0, 0, 0.3);
        padding: 15px;
        border-radius: 10px;
        text-align: left;
    }

    .history ul { list-style: none; padding: 0; color: #aaa; font-size: 0.9rem; }

    @@keyframes shake {
        0% { transform: translate(1px, 1px) rotate(0deg); }
        25% { transform: translate(-1px, -2px) rotate(-1deg); }
        50% { transform: translate(-3px, 0px) rotate(1deg); }
        75% { transform: translate(3px, 2px) rotate(0deg); }
        100% { transform: translate(1px, -1px) rotate(-1deg); }
    }

    @@keyframes scaleIn {
        0% { transform: scale(0); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
    }

    .loader {
        border: 4px solid rgba(255,255,255,0.3);
        border-top: 4px solid white;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        animation: spin 1s linear infinite;
        display: inline-block;
    }

    @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>

@code {
    private string message = "Ready to open?";
    private string lastWinIcon = "";
    private bool isOpening = false;
    private List<string> recentWins = new();
    private int hydratedPlayerId;
    private int analysisProgress;

    protected override async Task OnInitializedAsync()
    {
        Status.OnResourceChanged += HandleResourceChanged;
        await EnsureLoadedAsync();
    }

    private async Task EnsureLoadedAsync()
    {
        if (PlayerService.SelectedPlayerId <= 0 || hydratedPlayerId == PlayerService.SelectedPlayerId)
        {
            return;
        }

        hydratedPlayerId = PlayerService.SelectedPlayerId;
        await LoadData();
    }

    private async void HandleResourceChanged()
    {
        try
        {
            await EnsureLoadedAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Lootbox resource handler failed: {ex.Message}");
        }
    }

    private async Task LoadData()
    {
        if (PlayerService.SelectedPlayerId <= 0)
        {
            return;
        }

        var townBuildings = await Http.GetFromJsonAsync<List<PlayerTownBuilding>>($"api/game/player/{PlayerService.SelectedPlayerId}/town")
            ?? new List<PlayerTownBuilding>();
        PlayerService.UpdateTownBuildings(townBuildings);

        var player = await Http.GetFromJsonAsync<Player>($"api/game/player/{PlayerService.SelectedPlayerId}");
        if (player is not null)
        {
            PlayerService.UpdateFromPlayer(player);
        }
    }

    private async Task OpenBox()
    {
        if (PlayerService.SelectedPlayerId <= 0)
        {
            message = "Select a pilot first.";
            return;
        }

        if (PlayerService.Resource1 < 100)
        {
            message = "Not enough resources!";
            return;
        }

        isOpening = true;
        message = "Analyzing cargo...";
        analysisProgress = 0;

        for (var step = 1; step <= 10; step++)
        {
            await Task.Delay(180);
            analysisProgress = step * 10;
            await InvokeAsync(StateHasChanged);
        }

        var response = await Http.PostAsJsonAsync("api/game/lootbox", PlayerService.SelectedPlayerId);
        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<LootboxResult>();
            if (result != null)
            {
                message = result.Message;

                lastWinIcon = result.Icon;
                PlayerService.Resource1 = result.NewResource1;
                PlayerService.Resource2 = result.NewResource2;
                PlayerService.Alloy = result.NewResource3;
                PlayerService.Biomass = result.NewResource4;
                PlayerService.CurrentXP = result.NewPilotXP;
                PlayerService.CurrentLevel = result.NewPilotLevel;
                await RefreshAccountProgressAsync();

                recentWins.Insert(0, message);
                if (recentWins.Count > 5) recentWins.RemoveAt(5);
            }
        }
        else
        {
            message = "Error opening lootbox.";
        }

        Status.NotifyResourceChanged();
        isOpening = false;
        analysisProgress = 0;
    }

    public void Dispose()
    {
        Status.OnResourceChanged -= HandleResourceChanged;
    }

    private async Task RefreshAccountProgressAsync()
    {
        if (PlayerService.AccountProfileId <= 0)
        {
            return;
        }

        var account = await Http.GetFromJsonAsync<AccountProfile>($"api/game/account/{PlayerService.AccountProfileId}");
        if (account is not null)
        {
            PlayerService.UpdateAccount(account);
        }
    }

}