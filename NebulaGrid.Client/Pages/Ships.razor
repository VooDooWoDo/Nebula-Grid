@page "/ships"
@using System.Net.Http.Json
@using NebulaGrid.Shared.Models
@using NebulaGrid.Shared.Services
@inject PlayerService PlayerService
@inject GameStatus Status
@inject HttpClient HttpClient
@implements IDisposable

<PageTitle>Ship Hangar</PageTitle>

@if (!PlayerService.IsAreaUnlocked("ships"))
{
    <div class="hangar-container">
        <h1>🛸 Ship Terminal</h1>
        <div class="resource-header">Hangar is locked. @PlayerService.GetUnlockText("ships"). Current Pilot Level: @PlayerService.CurrentLevel.</div>
    </div>
}
else
{

<style>
    .hangar-container { padding: 20px; color: white; font-family: 'Segoe UI', sans-serif; }
    .ship-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 20px; }
    .ship-card { background: rgba(20, 20, 40, 0.9); border: 2px solid #333; border-radius: 12px; padding: 20px; text-align: center; transition: all 0.3s; }
    .ship-card.active { border-color: #00d4ff; box-shadow: 0 0 15px rgba(0, 212, 255, 0.5); transform: translateY(-5px); }
    .ship-icon { font-size: 3rem; display: block; margin-bottom: 10px; }
    .stat { font-size: 0.9rem; color: #aaa; margin-bottom: 5px; }
    .btn-action { color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; margin-top: 15px; width: 100%; font-weight: bold; transition: opacity 0.2s; }
    .btn-buy { background: #004e92; }
    .btn-equip { background: #28a745; }
    .btn-action:disabled { background: #222; color: #555; cursor: not-allowed; }
    .status-text { color: #00d4ff; font-weight: bold; margin-top: 15px; display: block; letter-spacing: 1px; }
    .resource-header { color: #00d4ff; font-size: 1.2rem; margin-bottom: 20px; border-bottom: 1px solid #333; padding-bottom: 10px; }
</style>

<div class="hangar-container">
    <h1>🛸 Ship Terminal</h1>
    <div class="resource-header">
        Available Credits: <strong style="color: #ffd700;">@PlayerService.Resource1</strong>
        • Available Alloy: <strong style="color: #92ffc6;">@PlayerService.Alloy</strong>
    </div>

    <div class="ship-grid">
        @foreach (var ship in ships)
        {
            var isEquipped = PlayerService.CurrentShipId == ship.ShipID;
            var isOwned = ownedShipIds.Contains(ship.ShipID);
            var (creditPrice, alloyPrice) = GetShipPrice(ship.ShipID, ship.EngineLevel);

            <div class="ship-card @(isEquipped ? "active" : "")">
                <span class="ship-icon">@(ship.ShipID == 1 ? "🚀" : ship.ShipID == 2 ? "🛸" : "🛰️")</span>
                <h3>@ship.ModelName</h3>
                <div class="stat">Engine Level: @ship.EngineLevel</div>
                <div class="stat">Travel Time: @ship.TravelDurationSeconds.ToString("0.00")s</div>
                <div class="stat">Cargo: @ship.CargoCapacity</div>

                @if (isEquipped)
                {
                    <span class="status-text">✨ EQUIPPED</span>
                }
                else if (isOwned)
                {
                    <button class="btn-action btn-equip" @onclick="() => EquipShipAsync(ship.ShipID)">
                        EQUIP
                    </button>
                }
                else
                {
                    <button class="btn-action btn-buy"
                            disabled="@(PlayerService.Resource1 < creditPrice || PlayerService.Alloy < alloyPrice)"
                            @onclick="() => BuyShipAsync(ship.ShipID)">
                        BUY (@creditPrice Credits / @alloyPrice Alloy)
                    </button>
                }
            </div>
        }
    </div>
</div>

}

@code {
    private List<Ship> ships = new();
    private HashSet<int> ownedShipIds = new();
    private int hydratedPlayerId;

    protected override async Task OnInitializedAsync()
    {
        Status.OnResourceChanged += HandleResourceChanged;
        await EnsureLoadedAsync();
    }

    private async Task EnsureLoadedAsync()
    {
        if (PlayerService.SelectedPlayerId <= 0 || hydratedPlayerId == PlayerService.SelectedPlayerId)
        {
            return;
        }

        hydratedPlayerId = PlayerService.SelectedPlayerId;
        await LoadHangarAsync();
    }

    private async void HandleResourceChanged()
    {
        await EnsureLoadedAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadHangarAsync()
    {
        ships = await HttpClient.GetFromJsonAsync<List<Ship>>("api/game/ships") ?? new List<Ship>();
        var ownedShips = await HttpClient.GetFromJsonAsync<List<OwnedShip>>($"api/game/player/{PlayerService.SelectedPlayerId}/ownedships") ?? new List<OwnedShip>();
        var player = await HttpClient.GetFromJsonAsync<Player>($"api/game/player/{PlayerService.SelectedPlayerId}");

        ownedShipIds = ownedShips.Select(ship => ship.ShipID).ToHashSet();
        PlayerService.OwnedShipIds = ownedShipIds;
        if (player is not null)
        {
            PlayerService.UpdateFromPlayer(player);
        }
    }

    private static (int CreditPrice, int AlloyPrice) GetShipPrice(int shipId, int engineLevel) => shipId switch
    {
        1 => (0, 0),
        2 => (600, 60),
        3 => (1800, 180),
        _ => (engineLevel * 150, engineLevel * 18)
    };

    private async Task BuyShipAsync(int shipId)
    {
        var response = await HttpClient.PostAsync($"api/game/player/{PlayerService.SelectedPlayerId}/buy-ship/{shipId}", null);
        if (!response.IsSuccessStatusCode)
        {
            return;
        }

        var player = await response.Content.ReadFromJsonAsync<Player>();
        if (player is not null)
        {
            PlayerService.UpdateFromPlayer(player);
        }

        await LoadHangarAsync();
        Status.NotifyResourceChanged();
    }

    private async Task EquipShipAsync(int shipId)
    {
        var response = await HttpClient.PostAsync($"api/game/player/{PlayerService.SelectedPlayerId}/equip-ship/{shipId}", null);
        if (!response.IsSuccessStatusCode)
        {
            return;
        }

        var player = await response.Content.ReadFromJsonAsync<Player>();
        if (player is not null)
        {
            PlayerService.UpdateFromPlayer(player);
        }

        await LoadHangarAsync();
        Status.NotifyResourceChanged();
    }

    public void Dispose()
    {
        Status.OnResourceChanged -= HandleResourceChanged;
    }
}
