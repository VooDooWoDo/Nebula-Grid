</style>

@code {
    private const int MaxBaseIntegrity = 20;
    private const int MaxTowerLevel = 10;
    private const int MaxWaveNumber = 40;
    private readonly List<TowerBlueprint> towerCatalog =
    [
        new("alloy-cannon", "Alloy Cannon", "Launches dense slugs into the lane and can be upgraded to push the wave cap higher.", "🛠️", 180, 0, 18, 0, 16, 24, 3, 0, "#92ffc6")
    ];

    private readonly List<TowerSlotModel> towerSlots = new();
    private readonly List<DefenseEnemy> activeEnemies = new();
    private readonly CancellationTokenSource loopCancellation = new();
    private Game5State game5State = new();
    private int selectedSlotIndex = -1;
    private bool waveInProgress;
    private int totalEnemiesToSpawn;
    private int spawnedEnemies;
    private int spawnCooldown;
    private int hydratedPlayerId;
    private string message = "Build your line and hold the sector.";

    protected override async Task OnInitializedAsync()
    {
        InitializeTowerSlots();
        Status.OnResourceChanged += HandleResourceChanged;
        await EnsureLoadedAsync();
        _ = RunBattleLoopAsync(loopCancellation.Token);
    }

    private async Task EnsureLoadedAsync()
    {
        if (PlayerService.SelectedPlayerId <= 0 || hydratedPlayerId == PlayerService.SelectedPlayerId)
        {
            return;
        }

        hydratedPlayerId = PlayerService.SelectedPlayerId;
        await LoadPlayerAsync();
        await LoadGame5StateAsync();
    }

    private async void HandleResourceChanged()
    {
        await EnsureLoadedAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadPlayerAsync()
    {
        if (PlayerService.SelectedPlayerId <= 0)
        {
            return;
        }

        var player = await HttpClient.GetFromJsonAsync<Player>($"api/game/player/{PlayerService.SelectedPlayerId}");
        if (player is not null)
        {
            PlayerService.UpdateFromPlayer(player);
        }
    }

    private async Task LoadGame5StateAsync()
    {
        if (PlayerService.SelectedPlayerId <= 0)
        {
            game5State = new Game5State();
            ApplyTowerLayout();
            return;
        }

        try
        {
            game5State = await HttpClient.GetFromJsonAsync<Game5State>($"api/game/player/{PlayerService.SelectedPlayerId}/game5state")
                ?? new Game5State { PlayerID = PlayerService.SelectedPlayerId };
        }
        catch
        {
            game5State = new Game5State { PlayerID = PlayerService.SelectedPlayerId };
        }

        game5State.WaveNumber = Math.Clamp(game5State.WaveNumber, 1, MaxWaveNumber);

        ApplyTowerLayout();
    }

    private void InitializeTowerSlots()
    {
        towerSlots.Clear();
        towerSlots.Add(new TowerSlotModel(0, 18, 28));
        towerSlots.Add(new TowerSlotModel(1, 38, 72));
        towerSlots.Add(new TowerSlotModel(2, 62, 28));
        towerSlots.Add(new TowerSlotModel(3, 82, 72));
    }

    private void ApplyTowerLayout()
    {
        var layout = (game5State.TowerLayout ?? string.Empty).Split('|');
        for (var index = 0; index < towerSlots.Count; index++)
        {
            var slotState = index < layout.Length ? layout[index] : string.Empty;
            if (string.IsNullOrWhiteSpace(slotState))
            {
                towerSlots[index].TowerKey = null;
                towerSlots[index].Level = 0;
            }
            else
            {
                var parts = slotState.Split(':', 2, StringSplitOptions.TrimEntries);
                towerSlots[index].TowerKey = parts[0];
                towerSlots[index].Level = parts.Length > 1 && int.TryParse(parts[1], out var parsedLevel)
                    ? Math.Clamp(parsedLevel, 1, MaxTowerLevel)
                    : 1;
            }

            towerSlots[index].CooldownTicks = 0;
        }
    }

    private string SerializeTowerLayout() => string.Join('|', towerSlots.Select(slot => string.IsNullOrWhiteSpace(slot.TowerKey) ? string.Empty : $"{slot.TowerKey}:{slot.Level}"));

    private async Task RunBattleLoopAsync(CancellationToken cancellationToken)
    {
        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                await Task.Delay(180, cancellationToken);
                if (!waveInProgress)
                {
                    continue;
                }

                await InvokeAsync(async () =>
                {
                    await StepBattleAsync();
                    StateHasChanged();
                });
            }
            catch (OperationCanceledException)
            {
                break;
            }
        }
    }

    private async Task StepBattleAsync()
    {
        if (spawnedEnemies < totalEnemiesToSpawn)
        {
            spawnCooldown--;
            if (spawnCooldown <= 0)
            {
                SpawnEnemy();
                spawnedEnemies++;
                spawnCooldown = Math.Max(2, 7 - Math.Min(4, game5State.WaveNumber / 2));
            }
        }

        foreach (var slot in towerSlots)
        {
            if (string.IsNullOrWhiteSpace(slot.TowerKey))
            {
                continue;
            }

            if (slot.CooldownTicks > 0)
            {
                slot.CooldownTicks--;
                continue;
            }

            var tower = GetTower(slot.TowerKey);
            if (tower is null)
            {
                continue;
            }

            var target = activeEnemies
                .Where(enemy => GetDistance(slot, enemy) <= GetTowerRange(slot, tower))
                .OrderByDescending(enemy => enemy.Progress)
                .FirstOrDefault();

            if (target is null)
            {
                continue;
            }

            var damage = GetTowerDamage(slot, tower) + PlayerService.MiningResearchLevel;
            target.Health -= damage;
            if (tower.SlowTicks > 0)
            {
                target.SlowTicks = Math.Max(target.SlowTicks, tower.SlowTicks + PlayerService.LogisticsResearchLevel / 2);
            }

            slot.CooldownTicks = GetTowerCooldownTicks(slot, tower);
        }

        var destroyedEnemies = activeEnemies.Where(enemy => enemy.Health <= 0).ToList();
        if (destroyedEnemies.Count > 0)
        {
            foreach (var enemy in destroyedEnemies)
            {
                activeEnemies.Remove(enemy);
                game5State.EnemiesDefeated++;
                game5State.TotalClicks++;
            }
        }

        var breached = false;
        foreach (var enemy in activeEnemies.ToList())
        {
            var speedModifier = enemy.SlowTicks > 0 ? 0.55 : 1.0;
            enemy.Progress += enemy.Speed * speedModifier;
            if (enemy.SlowTicks > 0)
            {
                enemy.SlowTicks--;
            }

            if (enemy.Progress < 100)
            {
                continue;
            }

            activeEnemies.Remove(enemy);
            game5State.BaseIntegrity = Math.Max(0, game5State.BaseIntegrity - 1);
            breached = game5State.BaseIntegrity <= 0;
        }

        if (breached)
        {
            await HandleBreachAsync();
            return;
        }

        if (spawnedEnemies >= totalEnemiesToSpawn && activeEnemies.Count == 0)
        {
            await CompleteWaveAsync();
        }
    }

    private void SpawnEnemy()
    {
        var wave = game5State.WaveNumber;
        activeEnemies.Add(new DefenseEnemy
        {
            Progress = 0,
            MaxHealth = 28 + (wave * 11),
            Health = 28 + (wave * 11),
            Speed = 2.8 + (wave * 0.16)
        });
    }

    private async Task StartWaveAsync()
    {
        if (waveInProgress)
        {
            return;
        }

        if (!towerSlots.Any(slot => !string.IsNullOrWhiteSpace(slot.TowerKey)))
        {
            message = "Build at least one tower before you start a wave.";
            return;
        }

        if (game5State.WaveNumber > GetWaveCap())
        {
            message = $"Upgrade your Alloy Cannons first. Current wave cap: {GetWaveCap()} / {MaxWaveNumber}.";
            return;
        }

        activeEnemies.Clear();
        spawnedEnemies = 0;
        totalEnemiesToSpawn = 5 + (game5State.WaveNumber * 2);
        spawnCooldown = 1;
        waveInProgress = true;
        message = $"Wave {game5State.WaveNumber} incoming. Hold the line.";
        await SaveGame5StateAsync();
    }

    private async Task CompleteWaveAsync()
    {
        waveInProgress = false;
        var wave = game5State.WaveNumber;
        var creditReward = 90 + (wave * 35);
        var fuelReward = 6 + (wave * 2);
        var alloyReward = 4 + (wave * 2);
        var biomassReward = 5 + (wave * 2);
        var xpReward = 18 + (wave * 6);

        PlayerService.Resource1 += creditReward;
        PlayerService.Resource2 += fuelReward;
        PlayerService.Alloy += alloyReward;
        PlayerService.Biomass += biomassReward;
        PlayerService.AddXP(xpReward);

        game5State.WaveNumber = Math.Min(MaxWaveNumber, game5State.WaveNumber + 1);
        game5State.BaseIntegrity = Math.Min(MaxBaseIntegrity, game5State.BaseIntegrity + 2);
        message = game5State.WaveNumber >= MaxWaveNumber && wave >= MaxWaveNumber
            ? $"Max wave held. +{creditReward} Credits, +{fuelReward} Fuel, +{alloyReward} Alloy, +{biomassReward} Biomass, +{xpReward} XP."
            : $"Wave cleared. +{creditReward} Credits, +{fuelReward} Fuel, +{alloyReward} Alloy, +{biomassReward} Biomass, +{xpReward} XP.";

        await SavePlayerAsync();
        await SaveGame5StateAsync();
        Status.NotifyResourceChanged();
    }

    private async Task HandleBreachAsync()
    {
        waveInProgress = false;
        activeEnemies.Clear();
        spawnedEnemies = 0;
        totalEnemiesToSpawn = 0;
        game5State.BaseIntegrity = MaxBaseIntegrity;
        game5State.WaveNumber = Math.Max(1, game5State.WaveNumber - 1);
        message = "Core breach. Defensive systems reset and the wave level drops by 1.";
        await SaveGame5StateAsync();
    }

    private async Task BuildTowerAsync(string towerKey)
    {
        if (selectedSlotIndex < 0)
        {
            message = "Select a tower slot first.";
            return;
        }

        var slot = towerSlots[selectedSlotIndex];
        if (!string.IsNullOrWhiteSpace(slot.TowerKey))
        {
            message = "The selected slot already has a tower.";
            return;
        }

        var tower = GetTower(towerKey);
        if (tower is null)
        {
            return;
        }

        if (!CanAfford(tower))
        {
            message = "Not enough resources for that tower.";
            return;
        }

        PlayerService.Resource1 -= tower.CreditCost;
        PlayerService.Resource2 -= tower.FuelCost;
        PlayerService.Alloy -= tower.AlloyCost;
        PlayerService.Biomass -= tower.BiomassCost;
        slot.TowerKey = tower.Key;
        slot.Level = Math.Max(1, slot.Level);
        slot.CooldownTicks = 0;
        message = $"{tower.Name} online in slot {selectedSlotIndex + 1}. Wave cap is now {GetWaveCap()} / {MaxWaveNumber}.";

        await SavePlayerAsync();
        await SaveGame5StateAsync();
        Status.NotifyResourceChanged();
    }

    private async Task UpgradeSelectedTowerAsync()
    {
        if (selectedSlotIndex < 0)
        {
            return;
        }

        var slot = towerSlots[selectedSlotIndex];
        var tower = GetTower(slot.TowerKey);
        if (tower is null || !CanUpgrade(slot))
        {
            return;
        }

        var cost = GetUpgradeCost(slot);
        PlayerService.Resource1 -= cost.Credits;
        PlayerService.Alloy -= cost.Alloy;
        slot.Level = Math.Min(MaxTowerLevel, slot.Level + 1);
        message = $"{tower.Name} upgraded to LVL {slot.Level}. Wave cap is now {GetWaveCap()} / {MaxWaveNumber}.";

        await SavePlayerAsync();
        await SaveGame5StateAsync();
        Status.NotifyResourceChanged();
    }

    private async Task SellSelectedTowerAsync()
    {
        if (selectedSlotIndex < 0)
        {
            return;
        }

        var slot = towerSlots[selectedSlotIndex];
        var tower = GetTower(slot.TowerKey);
        if (tower is null)
        {
            return;
        }

        PlayerService.Resource1 += tower.CreditCost / 2;
        PlayerService.Resource2 += tower.FuelCost / 2;
        PlayerService.Alloy += tower.AlloyCost / 2;
        PlayerService.Biomass += tower.BiomassCost / 2;
        slot.TowerKey = null;
        slot.Level = 0;
        slot.CooldownTicks = 0;
        message = $"{tower.Name} dismantled. Half the materials were recovered.";

        await SavePlayerAsync();
        await SaveGame5StateAsync();
        Status.NotifyResourceChanged();
    }

    private async Task RepairBaseAsync()
    {
        if (game5State.BaseIntegrity >= MaxBaseIntegrity || PlayerService.Alloy < 8 || PlayerService.Biomass < 12)
        {
            return;
        }

        PlayerService.Alloy -= 8;
        PlayerService.Biomass -= 12;
        game5State.BaseIntegrity = Math.Min(MaxBaseIntegrity, game5State.BaseIntegrity + 5);
        message = "Repair drones restored 5 base integrity.";

        await SavePlayerAsync();
        await SaveGame5StateAsync();
        Status.NotifyResourceChanged();
    }

    private async Task SaveGame5StateAsync()
    {
        if (PlayerService.SelectedPlayerId <= 0)
        {
            return;
        }

        try
        {
            game5State.PlayerID = PlayerService.SelectedPlayerId;
            game5State.TowerLayout = SerializeTowerLayout();
            game5State.LastSaved = DateTime.UtcNow;
            await HttpClient.PostAsJsonAsync($"api/game/player/{PlayerService.SelectedPlayerId}/savegame5state", game5State);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving game5 state: {ex.Message}");
        }
    }

    private async Task SavePlayerAsync()
    {
        if (PlayerService.SelectedPlayerId <= 0)
        {
            return;
        }

        var response = await HttpClient.PostAsJsonAsync("api/game/saveplayer", PlayerService.ToPlayer());
        response.EnsureSuccessStatusCode();
        await RefreshAccountProgressAsync();
    }

    private async Task RefreshAccountProgressAsync()
    {
        if (PlayerService.AccountProfileId <= 0)
        {
            return;
        }

        var account = await HttpClient.GetFromJsonAsync<AccountProfile>($"api/game/account/{PlayerService.AccountProfileId}");
        if (account is not null)
        {
            PlayerService.UpdateAccount(account);
        }
    }

    private void SelectSlot(int slotIndex)
    {
        selectedSlotIndex = slotIndex;
        message = $"Slot {slotIndex + 1} selected.";
    }

    private bool CanAfford(TowerBlueprint tower)
    {
        return PlayerService.Resource1 >= tower.CreditCost
            && PlayerService.Resource2 >= tower.FuelCost
            && PlayerService.Alloy >= tower.AlloyCost
            && PlayerService.Biomass >= tower.BiomassCost;
    }

    private bool CanUpgrade(TowerSlotModel slot)
    {
        if (string.IsNullOrWhiteSpace(slot.TowerKey) || slot.Level >= MaxTowerLevel)
        {
            return false;
        }

        var cost = GetUpgradeCost(slot);
        return PlayerService.Resource1 >= cost.Credits && PlayerService.Alloy >= cost.Alloy;
    }

    private TowerBlueprint? GetTower(string? towerKey) => towerCatalog.FirstOrDefault(tower => string.Equals(tower.Key, towerKey, StringComparison.OrdinalIgnoreCase));

    private string GetSelectedSlotText()
    {
        if (selectedSlotIndex < 0)
        {
            return "No slot selected. Pick one of the four build pads in the arena.";
        }

        var slot = towerSlots[selectedSlotIndex];
        var tower = GetTower(slot.TowerKey);
        return tower is null
            ? $"Slot {selectedSlotIndex + 1} is empty and ready for construction."
            : $"Slot {selectedSlotIndex + 1} hosts {tower.Name} at LVL {slot.Level}. Upgrade it to push damage and wave access higher.";
    }

    private (int Credits, int Alloy) GetUpgradeCost(TowerSlotModel slot)
    {
        var nextLevel = Math.Max(1, slot.Level);
        return (120 + (nextLevel * 70), 8 + (nextLevel * 6));
    }

    private int GetWaveCap() => Math.Min(MaxWaveNumber, towerSlots.Sum(slot => slot.Level));

    private double GetWaveCapPercent() => MaxWaveNumber <= 0 ? 0 : Math.Clamp(GetWaveCap() * 100d / MaxWaveNumber, 0, 100);

    private double GetTowerLevelPercent(TowerSlotModel slot) => MaxTowerLevel <= 0 ? 0 : Math.Clamp(slot.Level * 100d / MaxTowerLevel, 0, 100);

    private int GetTowerDamage(TowerSlotModel slot, TowerBlueprint tower) => tower.Damage + ((Math.Max(1, slot.Level) - 1) * 4);

    private int GetTowerRange(TowerSlotModel slot, TowerBlueprint tower) => tower.Range + ((Math.Max(1, slot.Level) - 1) * 2);

    private int GetTowerCooldownTicks(TowerSlotModel slot, TowerBlueprint tower)
    {
        var reactorBonus = PlayerService.ReactorResearchLevel > 0 ? 1 : 0;
        var levelBonus = (Math.Max(1, slot.Level) - 1) / 3;
        return Math.Max(1, tower.CooldownTicks - reactorBonus - levelBonus);
    }

    private double GetDistance(TowerSlotModel slot, DefenseEnemy enemy)
    {
        var enemyX = GetEnemyX(enemy.Progress);
        var dx = slot.X - enemyX;
        var dy = slot.Y - 50;
        return Math.Sqrt((dx * dx) + (dy * dy));
    }

    private double GetEnemyX(double progress) => 6 + (progress * 0.88);

    private string GetEnemyHealthPercent(DefenseEnemy enemy)
    {
        if (enemy.MaxHealth <= 0)
        {
            return "0";
        }

        var percent = Math.Clamp((enemy.Health / enemy.MaxHealth) * 100.0, 0, 100);
        return percent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    }

    private RenderFragment RenderCost(string label, int value) => builder =>
    {
        if (value <= 0)
        {
            return;
        }

        builder.OpenElement(0, "span");
        builder.AddContent(1, $"{label} {value}");
        builder.CloseElement();
    };

    public void Dispose()
    {
        loopCancellation.Cancel();
        Status.OnResourceChanged -= HandleResourceChanged;
        loopCancellation.Dispose();
    }

    private sealed record TowerBlueprint(string Key, string Name, string Description, string Icon, int CreditCost, int FuelCost, int AlloyCost, int BiomassCost, int Damage, int Range, int CooldownTicks, int SlowTicks, string Accent);

    private sealed class TowerSlotModel
    {
        public TowerSlotModel(int index, double x, double y)
        {
            Index = index;
            X = x;
            Y = y;
        }

        public int Index { get; }
        public double X { get; }
        public double Y { get; }
        public string? TowerKey { get; set; }
        public int Level { get; set; }
        public int CooldownTicks { get; set; }
    }

    private sealed class DefenseEnemy
    {
        public double Progress { get; set; }
        public double Health { get; set; }
        public double MaxHealth { get; set; }
        public double Speed { get; set; }
        public int SlowTicks { get; set; }
    }
}