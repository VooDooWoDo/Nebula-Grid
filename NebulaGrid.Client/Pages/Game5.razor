@page "/game5"
@using System.Net.Http.Json
@using NebulaGrid.Shared.Models
@using NebulaGrid.Shared.Services
@inject PlayerService PlayerService
@inject GameStatus Status
@inject HttpClient HttpClient
@implements IDisposable

<PageTitle>Defense Grid - Nebula Grid</PageTitle>

@if (!PlayerService.IsAreaUnlocked("game5"))
{
    <div class="defense-lock">
        <h2>Defense Grid locked</h2>
        <p>@PlayerService.GetUnlockText("game5"). Current Pilot Level: @PlayerService.CurrentLevel.</p>
    </div>
}
else
{
    <div class="defense-shell">
        <section class="defense-battlefield">
            <div class="battlefield-header">
                <div class="header-chip">Wave @game5State.WaveNumber</div>
                <div class="header-chip">Wave Cap @GetWaveCap() / @MaxWaveNumber</div>
                <div class="header-chip">Base @game5State.BaseIntegrity / 20</div>
                <div class="header-chip">Kills @game5State.EnemiesDefeated</div>
                <div class="header-chip">Enemies @activeEnemies.Count / @totalEnemiesToSpawn</div>
            </div>

            <div class="message-banner">@message</div>

            <div class="battlefield-stage">
                <div class="path-track"></div>
                <div class="path-start">ENTRY</div>
                <div class="path-end">CORE</div>

                @foreach (var slot in towerSlots)
                {
                    var blueprint = GetTower(slot.TowerKey);
                    <button class="tower-slot @(selectedSlotIndex == slot.Index ? "selected" : string.Empty) @(slot.TowerKey is null ? "empty" : "filled")"
                            style="left: @slot.X%; top: @slot.Y%;"
                            @onclick="() => SelectSlot(slot.Index)">
                        @if (blueprint is null)
                        {
                            <span>+</span>
                        }
                        else
                        {
                            <div class="slot-stack">
                                <span class="slot-icon">@blueprint.Icon</span>
                                <small>@blueprint.Name</small>
                            </div>
                        }
                    </button>
                }

                @foreach (var enemy in activeEnemies)
                {
                    <div class="enemy-drone" @key="enemy" style="left: @GetEnemyX(enemy.Progress)%; top: 50%;">
                        <span>🤖</span>
                        <div class="enemy-bar">
                            <div class="enemy-bar-fill" style="width: @GetEnemyHealthPercent(enemy)%"></div>
                        </div>
                    </div>
                }
            </div>

            <div class="battlefield-footer">
                <button class="action-button start" @onclick="StartWaveAsync" disabled="@waveInProgress">Start wave</button>
                <button class="action-button repair" @onclick="RepairBaseAsync" disabled="@(waveInProgress || game5State.BaseIntegrity >= 20 || PlayerService.Alloy < 8 || PlayerService.Biomass < 12)">Repair base (8 Alloy / 12 Biomass)</button>
                <button class="action-button sell" @onclick="SellSelectedTowerAsync" disabled="@(selectedSlotIndex < 0 || towerSlots[selectedSlotIndex].TowerKey is null)">Sell selected tower</button>
            </div>
        </section>

        <aside class="defense-sidebar">
            <div class="selection-panel">
                <strong>Selected Slot</strong>
                <p>@GetSelectedSlotText()</p>

                <div class="level-panel">
                    <div class="level-row">
                        <span>Defense Progress</span>
                        <span>@GetWaveCap() / @MaxWaveNumber</span>
                    </div>
                    <div class="level-track">
                        <div class="level-fill" style="width: @GetWaveCapPercent().ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                    </div>
                    <small>Bring all four Alloy Cannons near LVL 10 to reach the max wave.</small>
                </div>

                @if (selectedSlotIndex >= 0 && towerSlots[selectedSlotIndex].TowerKey is not null)
                {
                    var selectedSlot = towerSlots[selectedSlotIndex];
                    var upgradeCost = GetUpgradeCost(selectedSlot);
                    <div class="level-panel tower-level-panel">
                        <div class="level-row">
                            <span>Alloy Cannon LVL</span>
                            <span>@selectedSlot.Level / @MaxTowerLevel</span>
                        </div>
                        <div class="level-track">
                            <div class="level-fill" style="width: @GetTowerLevelPercent(selectedSlot).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                        </div>
                        <small>Upgrade unlocks more damage, range, and wave access.</small>
                    </div>
                    <button class="action-button upgrade"
                            @onclick="UpgradeSelectedTowerAsync"
                            disabled="@(waveInProgress || !CanUpgrade(selectedSlot))">
                        @(selectedSlot.Level >= MaxTowerLevel
                            ? "Alloy Cannon maxed"
                            : $"Upgrade ({upgradeCost.Credits} Credits / {upgradeCost.Alloy} Alloy)")
                    </button>
                }
            </div>

            <div class="tower-market">
                @foreach (var tower in towerCatalog)
                {
                    <article class="tower-card" style="border-color: @tower.Accent;">
                        <div class="tower-card-head">
                            <span class="tower-icon">@tower.Icon</span>
                            <div>
                                <h4>@tower.Name</h4>
                                <p>@tower.Description</p>
                            </div>
                        </div>
                        <div class="tower-stats">
                            <span>DMG @tower.Damage</span>
                            <span>Range @tower.Range</span>
                            <span>Rate @tower.CooldownTicks</span>
                        </div>
                        <div class="tower-costs">
                            @RenderCost("Credits", tower.CreditCost)
                            @RenderCost("Fuel", tower.FuelCost)
                            @RenderCost("Alloy", tower.AlloyCost)
                            @RenderCost("Biomass", tower.BiomassCost)
                        </div>
                        <button class="action-button build"
                                @onclick="() => BuildTowerAsync(tower.Key)"
                                disabled="@(selectedSlotIndex < 0 || !CanAfford(tower) || towerSlots[selectedSlotIndex].TowerKey is not null)">
                            Build on selected slot
                        </button>
                    </article>
                }
            </div>
        </aside>
    </div>
}

<style>
