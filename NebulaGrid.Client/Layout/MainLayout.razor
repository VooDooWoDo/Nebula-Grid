@inherits LayoutComponentBase
@using System.Net.Http.Json
@using NebulaGrid.Shared.Models
@using NebulaGrid.Shared.Services
@using System.Reflection
@using System.Text.RegularExpressions
@implements IDisposable
@inject PlayerService PlayerService
@inject GameStatus Status
@inject NavigationManager NavManager
@inject HttpClient HttpClient
@inject IJSRuntime JSRuntime

<div class="page @(isSidebarVisible ? string.Empty : "sidebar-hidden")">
    @if (!string.IsNullOrWhiteSpace(levelUpPopupText))
    {
        <div class="level-up-popup-shell">
            <div class="level-up-popup">
                <span class="level-up-kicker">Level Up</span>
                <strong>@levelUpPopupText</strong>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(milestonePopupTitle))
    {
        <div class="achievement-popup-shell">
            <div class="achievement-popup" role="dialog" aria-modal="true" aria-label="Achievement Update">
                <span class="achievement-kicker">Achievement Update</span>
                <strong>@milestonePopupTitle</strong>
                <p>@milestonePopupText</p>
                @if (!string.IsNullOrWhiteSpace(milestonePopupProgress))
                {
                    <p class="achievement-next">Next: @milestonePopupProgress</p>
                }
                <button type="button" class="achievement-dismiss" @onclick="DismissMilestonePopup">Got it</button>
            </div>
        </div>
    }

    @if (isSidebarVisible)
    {
        <div class="sidebar">
            <NavMenu />
        </div>
    }

    <main>
        <div class="top-row px-4">
            <div class="top-row-left">
                <button class="layout-toggle" @onclick="ToggleSidebarAsync">@SidebarToggleText</button>
                @if (ShouldShowGalaxyShortcut)
                {
                    <button class="layout-toggle galaxy-shortcut" @onclick="NavigateToGalaxy">Back to Galaxy</button>
                }
            </div>

            <div class="top-row-center">
                @if (PlayerService.SelectedPlayerId > 0)
                {
                    <div class="resource-cluster">
                        <button class="resource-chip commander-chip commander-button" title="@PlayerService.CommanderSummary" @onclick='() => NavManager.NavigateTo("/playerselection")'>
                            @PlayerService.PlayerName
                        </button>
                        <span class="resource-chip">Account: @PlayerService.AccountName</span>
                        <span class="resource-chip account-chip">Account LVL: @PlayerService.AccountLevel</span>
                        <span class="resource-chip account-chip">Account XP: @PlayerService.AccountXP/@PlayerService.AccountXPToNextLevel</span>
                        <span class="resource-chip pilot-chip">Pilot LVL: @PlayerService.CurrentLevel</span>
                        <span class="resource-chip pilot-chip">Pilot XP: @PlayerService.CurrentXP/@PlayerService.PilotXPToNextLevel</span>
                        <span class="resource-chip">Class: @PlayerService.CommanderSummary</span>
                        <span class="resource-chip">Credits: @PlayerService.Resource1</span>
                        <span class="resource-chip">Fuel: @PlayerService.Resource2</span>
                        <span class="resource-chip">Alloy: @PlayerService.Alloy</span>
                        <span class="resource-chip">Biomass: @PlayerService.Biomass</span>
                        <span class="resource-chip rate-chip">+@PlayerService.CreditsPerSecond Credits/s</span>
                        <span class="resource-chip rate-chip">+@PlayerService.AlloyPerSecond Alloy/s</span>
                        <span class="resource-chip rate-chip">+@PlayerService.FuelPerSecond Fuel/s</span>
                        <span class="resource-chip rate-chip">+@PlayerService.BiomassPerSecond Biomass/s</span>
                    </div>
                }
                else if (PlayerService.HasAccount)
                {
                    <div class="resource-cluster">
                        <span class="resource-chip">Restoring active pilot...</span>
                    </div>
                }
                else
                {
                    <div class="resource-cluster">
                        <span class="resource-chip">No active pilot selected</span>
                    </div>
                }
            </div>

            <div class="top-row-right">
                <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<style>
    .level-up-popup-shell {
        position: fixed;
        inset: 78px 0 auto 0;
        display: flex;
        justify-content: center;
        pointer-events: none;
        z-index: 1200;
    }

    .level-up-popup {
        min-width: 280px;
        padding: 14px 20px;
        border-radius: 18px;
        border: 1px solid rgba(255, 215, 92, 0.52);
        background: linear-gradient(135deg, rgba(28, 23, 8, 0.96), rgba(64, 42, 10, 0.92));
        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.34), 0 0 28px rgba(255, 196, 61, 0.18);
        text-align: center;
        color: #ffe7a6;
        animation: levelUpPopupIn 1.8s ease forwards;
    }

    .level-up-kicker {
        display: block;
        margin-bottom: 4px;
        font-size: 0.74rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: rgba(255, 231, 166, 0.8);
    }

    .level-up-popup strong {
        font-size: 1.08rem;
        font-weight: 800;
    }

    .achievement-popup-shell {
        position: fixed;
        inset: 0;
        display: grid;
        place-items: center;
        z-index: 1250;
        background: rgba(2, 6, 12, 0.5);
        backdrop-filter: blur(6px);
    }

    .achievement-popup {
        width: min(540px, calc(100vw - 24px));
        padding: 20px 22px;
        border-radius: 20px;
        border: 1px solid rgba(143, 220, 255, 0.32);
        background: linear-gradient(165deg, rgba(10, 17, 30, 0.98), rgba(13, 23, 40, 0.98));
        box-shadow: 0 24px 50px rgba(0, 0, 0, 0.42);
        color: #eff6ff;
    }

    .achievement-kicker {
        display: block;
        margin-bottom: 8px;
        font-size: 0.74rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #8fdcff;
    }

    .achievement-popup strong {
        display: block;
        font-size: 1.12rem;
        margin-bottom: 8px;
    }

    .achievement-popup p {
        margin: 0;
        line-height: 1.45;
        color: rgba(239, 246, 255, 0.84);
    }

    .achievement-next {
        margin-top: 10px !important;
        color: #ffd78e !important;
        font-weight: 700;
    }

    .achievement-dismiss {
        margin-top: 16px;
        border: none;
        border-radius: 12px;
        padding: 10px 14px;
        font-weight: 700;
        color: #07101c;
        background: #8fdcff;
        cursor: pointer;
    }

    @@keyframes levelUpPopupIn {
        0% { opacity: 0; transform: translateY(-14px) scale(0.96); }
        12% { opacity: 1; transform: translateY(0) scale(1); }
        82% { opacity: 1; transform: translateY(0) scale(1); }
        100% { opacity: 0; transform: translateY(-10px) scale(0.98); }
    }
</style>

@code {
    private static readonly (string AreaKey, string DisplayName)[] GalaxyUnlockAreas =
    [
        ("game1", "Command Nexus"),
        ("game2", "Asteroid Belt"),
        ("ships", "Hangar"),
        ("lootbox", "Stellar Cargo"),
        ("academy", "Pilot Academy"),
        ("game3", "Bio Dome"),
        ("research", "Research Lab"),
        ("game4", "Reactor Core"),
        ("game5", "Defense Grid")
    ];

    private static readonly (int SlotId, int AccountLevelRequired)[] AccountSlotUnlocks =
    [
        (2, 2),
        (3, 5),
        (4, 7)
    ];

    private const string SelectedAccountStorageKey = "nebula.selected-account-id";
    private const string SelectedPlayerStorageKey = "nebula.selected-player-id";
    private const string SidebarVisibleStorageKey = "nebula.sidebar-visible";
    private System.Threading.Timer? automationTimer;
    private bool isApplyingAutomation;
    private bool isHydratingContext;
    private bool isSessionReady;
    private bool isSidebarVisible = true;
    private int unsavedAutomationTicks;
    private string? levelUpPopupText;
    private int levelUpPopupVersion;
    private string? milestonePopupTitle;
    private string? milestonePopupText;
    private string? milestonePopupProgress;

    private string SidebarToggleText => isSidebarVisible ? "Hide Nav" : "Show Nav";
    private bool ShouldShowGalaxyShortcut => !isSidebarVisible && PlayerService.SelectedPlayerId > 0 && !IsCurrentRoute("galaxy");

    private string AppVersion => appVersion;
    private string appVersion = (typeof(Program).Assembly
        .GetCustomAttribute<AssemblyInformationalVersionAttribute>()?
        .InformationalVersion ?? "1.0.0-alpha").Split('+')[0];

    protected override void OnInitialized()
    {
        Status.OnResourceChanged += HandleResourceChanged;
        PlayerService.OnLevelUp += HandleLevelUp;
        PlayerService.OnAccountSlotsUnlocked += HandleAccountSlotsUnlocked;
        NavManager.LocationChanged += HandleLocationChanged;
        automationTimer = new System.Threading.Timer(_ => InvokeAsync(ApplyAutomationTickAsync), null, 1000, 1000);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            await LoadAppVersionFromChangelogAsync();
            isSessionReady = true;
            await JSRuntime.InvokeVoidAsync("nebulaStorage.registerLastActiveOnClose", HttpClient.BaseAddress?.ToString() ?? NavManager.BaseUri, SelectedPlayerStorageKey);
            await RestoreLayoutPreferencesAsync();
            await RestorePlayerContextAsync();

            if (IsCurrentRoute("") || IsCurrentRoute("galaxy"))
            {
                NavManager.NavigateTo("/accounts", replace: true);
                return;
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Initial layout bootstrap failed: {ex.Message}");
            PlayerService.ClearAccountContext();
            await ClearSelectedAccountAsync();
            await ClearSelectedPlayerAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RestoreLayoutPreferencesAsync()
    {
        try
        {
            var storedSidebarVisible = await JSRuntime.InvokeAsync<string?>("nebulaStorage.get", SidebarVisibleStorageKey);
            if (bool.TryParse(storedSidebarVisible, out var visible))
            {
                isSidebarVisible = visible;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Layout preference restore failed: {ex.Message}");
        }
    }

    private async Task LoadAppVersionFromChangelogAsync()
    {
        try
        {
            var changelog = await HttpClient.GetStringAsync("CHANGELOG.md");
            var match = Regex.Match(changelog, @"(?m)^##\s+([0-9A-Za-z\.-]+)\s+-\s+\d{4}-\d{2}-\d{2}\s*$");
            if (match.Success)
            {
                appVersion = match.Groups[1].Value;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Version resolve from changelog failed: {ex.Message}");
        }
    }

    private async Task ToggleSidebarAsync()
    {
        isSidebarVisible = !isSidebarVisible;
        await JSRuntime.InvokeVoidAsync("nebulaStorage.set", SidebarVisibleStorageKey, isSidebarVisible.ToString().ToLowerInvariant());
    }

    private async void HandleResourceChanged()
    {
        try
        {
            if (isSessionReady)
            {
                await PersistSelectedAccountAsync();
                await PersistSelectedPlayerAsync();
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Resource change handler failed: {ex.Message}");
        }
    }

    private void ShowPilotLevelAchievement(PlayerService.LevelUpNotification notification)
    {
        if (notification.NewLevel <= 0)
        {
            return;
        }

        var startLevel = Math.Max(1, notification.NewLevel - Math.Max(1, notification.LevelsGained) + 1);
        var newlyUnlockedAreas = GetGalaxyUnlocksInRange(startLevel, notification.NewLevel);
        var nextUnlock = GetNextGalaxyUnlock(notification.NewLevel);

        milestonePopupTitle = $"Pilot Level {notification.NewLevel}";
        milestonePopupText = newlyUnlockedAreas.Count > 0
            ? $"{FormatAreaList(newlyUnlockedAreas)} unlocked."
            : "No new galaxy unlocks at this level.";
        milestonePopupProgress = nextUnlock is null
            ? "All galaxy zones unlocked."
            : $"Pilot Level {nextUnlock.Value.Level}: {FormatAreaList(nextUnlock.Value.Areas)}";
    }

    private List<string> GetGalaxyUnlocksInRange(int startLevel, int endLevel)
    {
        var unlocked = new List<string>();
        foreach (var area in GalaxyUnlockAreas)
        {
            var requiredLevel = PlayerService.GetRequiredLevelForArea(area.AreaKey);
            if (requiredLevel >= startLevel && requiredLevel <= endLevel)
            {
                unlocked.Add(area.DisplayName);
            }
        }

        return unlocked;
    }

    private (int Level, List<string> Areas)? GetNextGalaxyUnlock(int currentLevel)
    {
        var nextLevel = int.MaxValue;
        foreach (var area in GalaxyUnlockAreas)
        {
            var requiredLevel = PlayerService.GetRequiredLevelForArea(area.AreaKey);
            if (requiredLevel > currentLevel && requiredLevel < nextLevel)
            {
                nextLevel = requiredLevel;
            }
        }

        if (nextLevel == int.MaxValue)
        {
            return null;
        }

        var areas = GalaxyUnlockAreas
            .Where(area => PlayerService.GetRequiredLevelForArea(area.AreaKey) == nextLevel)
            .Select(area => area.DisplayName)
            .ToList();

        return (nextLevel, areas);
    }

    private static string FormatAreaList(IReadOnlyList<string> areas)
    {
        if (areas.Count == 0)
        {
            return "";
        }

        if (areas.Count == 1)
        {
            return areas[0];
        }

        if (areas.Count == 2)
        {
            return $"{areas[0]} and {areas[1]}";
        }

        return string.Join(", ", areas.Take(areas.Count - 1)) + $", and {areas[^1]}";
    }

    private void DismissMilestonePopup()
    {
        milestonePopupTitle = null;
        milestonePopupText = null;
        milestonePopupProgress = null;
    }

    private void HandleAccountSlotsUnlocked(int previousUnlockedSlots, int newUnlockedSlots)
    {
        if (newUnlockedSlots <= previousUnlockedSlots)
        {
            return;
        }

        var newlyUnlockedSlots = AccountSlotUnlocks
            .Where(slot => slot.SlotId > previousUnlockedSlots && slot.SlotId <= newUnlockedSlots)
            .OrderBy(slot => slot.SlotId)
            .ToList();

        if (newlyUnlockedSlots.Count == 0)
        {
            return;
        }

        milestonePopupTitle = newlyUnlockedSlots.Count == 1
            ? $"Pilot Slot {newlyUnlockedSlots[0].SlotId} Unlocked"
            : "New Pilot Slots Unlocked";

        var unlockedDetails = string.Join(
            " ",
            newlyUnlockedSlots.Select(slot => $"Slot {slot.SlotId} is now unlocked (Account LVL {slot.AccountLevelRequired})."));

        milestonePopupText = unlockedDetails;

        var nextUnlock = AccountSlotUnlocks
            .Where(slot => slot.SlotId > newUnlockedSlots)
            .OrderBy(slot => slot.AccountLevelRequired)
            .FirstOrDefault();

        milestonePopupProgress = nextUnlock == default
            ? "All pilot slots are unlocked."
            : $"Next: Slot {nextUnlock.SlotId} at Account LVL {nextUnlock.AccountLevelRequired}";
    }

    private void HandleLevelUp(PlayerService.LevelUpNotification notification)
    {
        if (string.Equals(notification.Scope, "Pilot", StringComparison.OrdinalIgnoreCase))
        {
            ShowPilotLevelAchievement(notification);
            _ = InvokeAsync(StateHasChanged);
            return;
        }

        if (string.Equals(notification.Scope, "Account", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        levelUpPopupVersion++;
        var popupVersion = levelUpPopupVersion;
        var label = string.Equals(notification.Scope, "Account", StringComparison.OrdinalIgnoreCase)
            ? "Account LVL"
            : "Pilot LVL";

        levelUpPopupText = notification.LevelsGained > 1
            ? $"{notification.Name} reached {label} {notification.NewLevel} (+{notification.LevelsGained})"
            : $"{notification.Name} reached {label} {notification.NewLevel}";

        _ = Task.Run(async () =>
        {
            await Task.Delay(1800);
            await InvokeAsync(() =>
            {
                if (popupVersion != levelUpPopupVersion)
                {
                    return;
                }

                levelUpPopupText = null;
                StateHasChanged();
            });
        });

        _ = InvokeAsync(StateHasChanged);
    }

    private async Task ApplyAutomationTickAsync()
    {
        if (isApplyingAutomation || PlayerService.SelectedPlayerId <= 0)
        {
            return;
        }

        isApplyingAutomation = true;

        try
        {
            var changed = PlayerService.ApplyPassiveIncome();
            if (!changed)
            {
                return;
            }

            unsavedAutomationTicks++;
            Status.NotifyResourceChanged();

            if (unsavedAutomationTicks >= 5)
            {
                await SavePlayerProgressAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Automation tick failed: {ex.Message}");
        }
        finally
        {
            isApplyingAutomation = false;
        }
    }

    private async void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        try
        {
            await EnsurePlayerContextHydratedAsync();
            await FlushPendingProgressAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Location change handler failed: {ex.Message}");
        }
    }

    private async Task EnsurePlayerContextHydratedAsync()
    {
        if (isHydratingContext || PlayerService.SelectedPlayerId > 0)
        {
            return;
        }

        isHydratingContext = true;
        try
        {
            await RestorePlayerContextAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Context hydration on navigation failed: {ex.Message}");
        }
        finally
        {
            isHydratingContext = false;
        }
    }

    private void NavigateToGalaxy()
    {
        NavManager.NavigateTo("/galaxy");
    }

    private bool IsCurrentRoute(string route)
    {
        var relativePath = NavManager.ToBaseRelativePath(NavManager.Uri).Trim('/');
        return string.Equals(relativePath, route.Trim('/'), StringComparison.OrdinalIgnoreCase);
    }

    private async Task FlushPendingProgressAsync()
    {
        if (PlayerService.SelectedPlayerId <= 0 || unsavedAutomationTicks <= 0)
        {
            return;
        }

        try
        {
            await SavePlayerProgressAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Progress flush failed: {ex.Message}");
        }
    }

    private async Task SavePlayerProgressAsync()
    {
        var response = await HttpClient.PostAsJsonAsync("api/game/saveplayer", PlayerService.ToPlayer());
        response.EnsureSuccessStatusCode();
        await RefreshAccountProgressAsync();
        unsavedAutomationTicks = 0;
    }

    private async Task RefreshAccountProgressAsync()
    {
        if (PlayerService.AccountProfileId <= 0)
        {
            return;
        }

        var account = await HttpClient.GetFromJsonAsync<AccountProfile>($"api/game/account/{PlayerService.AccountProfileId}");
        if (account is not null)
        {
            PlayerService.UpdateAccount(account);
        }
    }

    private async Task RestorePlayerContextAsync()
    {
        try
        {
            var storedAccountId = await JSRuntime.InvokeAsync<string?>("nebulaStorage.get", SelectedAccountStorageKey);
            if (!int.TryParse(storedAccountId, out var accountId) || accountId <= 0)
            {
                PlayerService.ClearAccountContext();
                await ClearSelectedPlayerAsync();
                return;
            }

            var accountResponse = await HttpClient.GetAsync($"api/game/account/{accountId}");
            if (accountResponse.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                PlayerService.ClearAccountContext();
                await ClearSelectedAccountAsync();
                await ClearSelectedPlayerAsync();
                return;
            }

            accountResponse.EnsureSuccessStatusCode();
            var account = await accountResponse.Content.ReadFromJsonAsync<AccountProfile>();
            if (account is null)
            {
                PlayerService.ClearAccountContext();
                await ClearSelectedAccountAsync();
                await ClearSelectedPlayerAsync();
                return;
            }

            PlayerService.UpdateAccount(account);

            if (PlayerService.SelectedPlayerId > 0)
            {
                await PersistSelectedPlayerAsync();
                return;
            }

            var storedPlayerId = await JSRuntime.InvokeAsync<string?>("nebulaStorage.get", SelectedPlayerStorageKey);
            if (!int.TryParse(storedPlayerId, out var playerId) || playerId <= 0)
            {
                return;
            }

            var player = await HttpClient.GetFromJsonAsync<Player>($"api/game/player/{playerId}");
            if (player is null || player.AccountProfileID != accountId)
            {
                await ClearSelectedPlayerAsync();
                return;
            }

            var upgrades = await HttpClient.GetFromJsonAsync<List<PlayerUpgrade>>($"api/game/player/{playerId}/upgrades") ?? new List<PlayerUpgrade>();
            var research = await HttpClient.GetFromJsonAsync<List<PlayerResearch>>($"api/game/player/{playerId}/research") ?? new List<PlayerResearch>();
            var townBuildings = await HttpClient.GetFromJsonAsync<List<PlayerTownBuilding>>($"api/game/player/{playerId}/town") ?? new List<PlayerTownBuilding>();
            var slots = await HttpClient.GetFromJsonAsync<List<CharacterSlotSummary>>($"api/game/account/{accountId}/slots") ?? new List<CharacterSlotSummary>();

            PlayerService.UpdateFromPlayer(player);
            PlayerService.UpdateMainPilotSupport(slots.Where(slot => slot.Player is not null).Select(slot => slot.Player!));
            PlayerService.SyncActivePilotPresentation();
            PlayerService.UpdateUpgrades(upgrades);
            PlayerService.UpdateResearch(research);
            PlayerService.UpdateTownBuildings(townBuildings);
            Status.NotifyResourceChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Player context restore failed: {ex.Message}");
            PlayerService.ClearAccountContext();
            await ClearSelectedPlayerAsync();
        }
    }

    private Task PersistSelectedAccountAsync()
    {
        return PlayerService.AccountProfileId > 0
            ? JSRuntime.InvokeVoidAsync("nebulaStorage.set", SelectedAccountStorageKey, PlayerService.AccountProfileId.ToString()).AsTask()
            : ClearSelectedAccountAsync();
    }

    private Task PersistSelectedPlayerAsync()
    {
        return PlayerService.SelectedPlayerId > 0
            ? JSRuntime.InvokeVoidAsync("nebulaStorage.set", SelectedPlayerStorageKey, PlayerService.SelectedPlayerId.ToString()).AsTask()
            : ClearSelectedPlayerAsync();
    }

    private Task ClearSelectedAccountAsync()
    {
        return JSRuntime.InvokeVoidAsync("nebulaStorage.remove", SelectedAccountStorageKey).AsTask();
    }

    private Task ClearSelectedPlayerAsync()
    {
        return JSRuntime.InvokeVoidAsync("nebulaStorage.remove", SelectedPlayerStorageKey).AsTask();
    }

    public void Dispose()
    {
        Status.OnResourceChanged -= HandleResourceChanged;
        PlayerService.OnLevelUp -= HandleLevelUp;
        PlayerService.OnAccountSlotsUnlocked -= HandleAccountSlotsUnlocked;
        NavManager.LocationChanged -= HandleLocationChanged;
        automationTimer?.Dispose();
    }

}
